function f_TC_AuthenticateClient_05_eUICC_Challenge_Reuse(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: AuthenticateClient - eUICC Challenge Reuse ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* First authentication flow */
    var RemoteProfileProvisioningRequest authRequest1 := f_create_initiate_authentication_request();
    var octetstring euiccChallenge1 := authRequest1.initiateAuthenticationRequest.euiccChallenge;
    var RemoteProfileProvisioningResponse authResponse1 := f_es9p_transceive_success(authRequest1);
    
    /* Second authentication with same euiccChallenge */
    var RemoteProfileProvisioningRequest authRequest2 := f_create_initiate_authentication_request();
    authRequest2.initiateAuthenticationRequest.euiccChallenge := euiccChallenge1;
    var RemoteProfileProvisioningResponse authResponse2 := f_es9p_transceive_error(authRequest2);
    
    if (ispresent(authResponse2.initiateAuthenticationResponse.initiateAuthenticationError)) {
        ext_logInfo("Received expected error for reused eUICC challenge");
        setverdict(pass);
    } else {
        setverdict(fail, "Expected error for reused eUICC challenge but got success");
    }
    
    f_rsp_client_cleanup();
}

/* Error test wrapper functions */
function f_TC_AuthenticateClient_Error_Generic(charstring id) runs on smdpp_ConnHdlr {
    var smdpp_ConnHdlrPars pars := g_pars_smdpp;
    ext_logInfo("=== Test Case: AuthenticateClient Error - " & pars.test_name & " ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* InitiateAuthentication */
    var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
    g_transactionId := authOk.transactionId;
    g_serverChallenge := authOk.serverSigned1.serverChallenge;
    
    /* Create AuthenticateClient request */
    var RemoteProfileProvisioningRequest authClientReq := f_create_authenticate_client_request();
    
    /* Apply error injection based on parameters */
    if (ispresent(pars.ac_error_injection)) {
        if (ispresent(pars.ac_error_injection.trans_error)) {
            if (pars.ac_error_injection.trans_error.in_json) {
                authClientReq.authenticateClientRequest.transactionId := 'DEADBEEF10'O;
            }
        }
        if (ispresent(pars.ac_error_injection.sig_error)) {
            /* Signature corruption would happen at encoding level */
        }
        if (ispresent(pars.ac_error_injection.challenge_error)) {
            authClientReq.authenticateClientRequest.authenticateServerResponse.serverChallenge := 
                f_generate_wrong_challenge();
        }
    }
    
    /* Send request and expect error */
    var RemoteProfileProvisioningResponse authClientResp := f_es9p_transceive_error(authClientReq);
    
    /* Validate error response */
    f_validate_error_response(
        authClientResp.authenticateClientResponse.authenticateClientError,
        pars.expected_subject_code,
        pars.expected_reason_code
    );
    
    f_rsp_client_cleanup();
    setverdict(pass);
}

/* GetBoundProfilePackage Test Cases */

function f_TC_GetBoundProfilePackage_01_Nominal(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: GetBoundProfilePackage - Nominal ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* Complete authentication flow */
    var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
    var AuthenticateClientOk authClientOk := f_authenticateClient(authOk);
    
    /* Store context */
    g_transactionId := authClientOk.transactionId;
    g_euicc_otpk := authClientOk.euiccSigned1.euiccOtpk;
    
    /* GetBoundProfilePackage */
    var PrepareDownloadResponse prepareDownloadResp := f_create_prepare_download_response(authClientOk.profileMetaData.smdpSigned2.smdpSignature2);
    var RemoteProfileProvisioningRequest gbppRequest := f_create_get_bound_profile_package_request(authClientOk.profileMetaData.smdpSigned2.smdpSignature2);
    gbppRequest.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp;
    
    var RemoteProfileProvisioningResponse gbppResponse := f_es9p_transceive_success(gbppRequest);
    var GetBoundProfilePackageOk gbppOk := gbppResponse.getBoundProfilePackageResponse.getBoundProfilePackageOk;
    
    /* Verify transaction ID */
    if (gbppOk.transactionId != g_transactionId) {
        setverdict(fail, "Transaction ID mismatch in GetBoundProfilePackage response");
        f_rsp_client_cleanup();
        return;
    }
    
    ext_logInfo("Test passed - GetBoundProfilePackage successful");
    f_rsp_client_cleanup();
    setverdict(pass);
}

function f_TC_GetBoundProfilePackage_02_Retry_Same_Challenge(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: GetBoundProfilePackage - Retry with Same Challenge ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* Complete initial authentication */
    var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
    var AuthenticateClientOk authClientOk := f_authenticateClient(authOk);
    
    /* First GetBoundProfilePackage */
    var octetstring smdpSignature2 := authClientOk.profileMetaData.smdpSigned2.smdpSignature2;
    var PrepareDownloadResponse prepareDownloadResp1 := f_create_prepare_download_response(smdpSignature2);
    var octetstring euiccChallenge2_1 := prepareDownloadResp1.euiccChallenge2;
    
    var RemoteProfileProvisioningRequest gbppRequest1 := f_create_get_bound_profile_package_request(smdpSignature2);
    gbppRequest1.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp1;
    var RemoteProfileProvisioningResponse gbppResponse1 := f_es9p_transceive_success(gbppRequest1);
    
    /* Second GetBoundProfilePackage with same euiccChallenge2 */
    var PrepareDownloadResponse prepareDownloadResp2 := f_create_prepare_download_response(smdpSignature2);
    prepareDownloadResp2.euiccChallenge2 := euiccChallenge2_1;
    
    var RemoteProfileProvisioningRequest gbppRequest2 := f_create_get_bound_profile_package_request(smdpSignature2);
    gbppRequest2.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp2;
    var RemoteProfileProvisioningResponse gbppResponse2 := f_es9p_transceive_error(gbppRequest2);
    
    if (ispresent(gbppResponse2.getBoundProfilePackageResponse.getBoundProfilePackageError)) {
        ext_logInfo("Received expected error for reused euiccChallenge2");
        setverdict(pass);
    } else {
        setverdict(fail, "Expected error for reused euiccChallenge2 but got success");
    }
    
    f_rsp_client_cleanup();
}

function f_TC_GetBoundProfilePackage_03_Retry_Different_Challenge(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: GetBoundProfilePackage - Retry with Different Challenge ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* Complete initial authentication */
    var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
    var AuthenticateClientOk authClientOk := f_authenticateClient(authOk);
    
    var octetstring smdpSignature2 := authClientOk.profileMetaData.smdpSigned2.smdpSignature2;
    
    /* First GetBoundProfilePackage */
    var PrepareDownloadResponse prepareDownloadResp1 := f_create_prepare_download_response(smdpSignature2);
    var RemoteProfileProvisioningRequest gbppRequest1 := f_create_get_bound_profile_package_request(smdpSignature2);
    gbppRequest1.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp1;
    var RemoteProfileProvisioningResponse gbppResponse1 := f_es9p_transceive_success(gbppRequest1);
    
    /* Second GetBoundProfilePackage with different euiccChallenge2 */
    var PrepareDownloadResponse prepareDownloadResp2 := f_create_prepare_download_response(smdpSignature2);
    var RemoteProfileProvisioningRequest gbppRequest2 := f_create_get_bound_profile_package_request(smdpSignature2);
    gbppRequest2.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp2;
    var RemoteProfileProvisioningResponse gbppResponse2 := f_es9p_transceive_success(gbppRequest2);
    
    /* Verify both succeeded */
    if (ispresent(gbppResponse2.getBoundProfilePackageResponse.getBoundProfilePackageOk)) {
        ext_logInfo("Test passed - Retry with different challenge successful");
        setverdict(pass);
    } else {
        setverdict(fail, "Expected success for different euiccChallenge2 but got error");
    }
    
    f_rsp_client_cleanup();
}

