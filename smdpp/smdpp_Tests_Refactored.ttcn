/* Complete Flow Test Case */

function f_TC_rsp_complete_flow(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: Complete RSP Flow ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* InitiateAuthentication */
    var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
    ext_logInfo("InitiateAuthentication successful - transactionId: " & hex2str(authOk.transactionId));
    
    /* AuthenticateClient */
    var AuthenticateClientOk authClientOk := f_authenticateClient(authOk);
    ext_logInfo("AuthenticateClient successful");
    
    /* GetBoundProfilePackage */
    var octetstring smdpSignature2 := authClientOk.profileMetaData.smdpSigned2.smdpSignature2;
    var PrepareDownloadResponse prepareDownloadResp := f_create_prepare_download_response(smdpSignature2);
    var RemoteProfileProvisioningRequest gbppRequest := f_create_get_bound_profile_package_request(smdpSignature2);
    gbppRequest.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp;
    var RemoteProfileProvisioningResponse gbppResponse := f_es9p_transceive_success(gbppRequest);
    ext_logInfo("GetBoundProfilePackage successful");
    
    /* HandleNotification */
    var ProfileInstallationResult pir := f_create_profile_installation_result(
        authClientOk.transactionId,
        authClientOk.profileMetaData.smdpOid,
        finalResult_successfulInstallation
    );
    f_handleNotification(hex2str(authClientOk.transactionId), pir);
    ext_logInfo("HandleNotification successful");
    
    ext_logInfo("Test passed - Complete RSP flow successful");
    f_rsp_client_cleanup();
    setverdict(pass);
}

/* Error Test Wrapper Functions */

function f_TC_AuthenticateClient_Error_Generic_Wrapper(charstring id) runs on smdpp_ConnHdlr {
    f_TC_AuthenticateClient_Error_Generic(id);
}

function f_TC_GetBoundProfilePackage_Error_Generic_Wrapper(charstring id) runs on smdpp_ConnHdlr {
    f_TC_GetBoundProfilePackage_Error_Generic(id);
}

