/* GetBoundProfilePackage Error Tests */

testcase TC_SM_DP_ES9_GetBoundProfilePackageNIST_Error_InvalidSignature() runs on MTC_CT {
    var smdpp_ConnHdlrPars pars := f_init_pars();
    pars.test_name := "Invalid Signature";
    pars.gbpp_error_injection := {
        sig_error := { corrupt_signature := true }
    };
    pars.expected_subject_code := "8.8.5";
    pars.expected_reason_code := "5.1";
    pars.cc_required := true;
    var smdpp_ConnHdlr vc_conn;
    
    f_init(testcasename());
    vc_conn := f_start_handler(refers(f_TC_GetBoundProfilePackage_Error_Generic_Wrapper), pars);
    vc_conn.done;
    setverdict(pass);
}

testcase TC_SM_DP_ES9_GetBoundProfilePackageNIST_Error_UnknownTransactionId() runs on MTC_CT {
    var smdpp_ConnHdlrPars pars := f_init_pars();
    pars.test_name := "Unknown Transaction ID";
    pars.gbpp_error_injection := {
        trans_error := { in_json := true }
    };
    pars.expected_subject_code := "8.10.1";
    pars.expected_reason_code := "3.9";
    pars.cc_required := false;
    var smdpp_ConnHdlr vc_conn;
    
    f_init(testcasename());
    vc_conn := f_start_handler(refers(f_TC_GetBoundProfilePackage_Error_Generic_Wrapper), pars);
    vc_conn.done;
    setverdict(pass);
}

