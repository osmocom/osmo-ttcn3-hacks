}

/* GetBoundProfilePackage Error Test Cases */
function f_TC_GetBoundProfilePackage_Error_Generic(charstring id) runs on smdpp_ConnHdlr {
    var smdpp_ConnHdlrPars pars := g_pars_smdpp;
    ext_logInfo("=== Test Case: GetBoundProfilePackage Error - " & pars.test_name & " ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* Complete authentication if required */
    if (pars.cc_required) {
        var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
        var AuthenticateClientOk authClientOk := f_authenticateClient(authOk);
        g_transactionId := authClientOk.transactionId;
    }
    
    /* Create GetBoundProfilePackage request */
    var RemoteProfileProvisioningRequest gbppRequest := f_create_get_bound_profile_package_request('DEADBEEF'O);
    
    /* Apply error injection based on parameters */
    if (ispresent(pars.gbpp_error_injection)) {
        if (ispresent(pars.gbpp_error_injection.trans_error)) {
            if (pars.gbpp_error_injection.trans_error.in_json) {
                gbppRequest.getBoundProfilePackageRequest.transactionId := 'BADC0FFEE0'O;
            }
        }
    }
    
    /* Send request and expect error */
    var RemoteProfileProvisioningResponse gbppResponse := f_es9p_transceive_error(gbppRequest);
    
    /* Validate error response */
    f_validate_error_response(
        gbppResponse.getBoundProfilePackageResponse.getBoundProfilePackageError,
        pars.expected_subject_code,
        pars.expected_reason_code
    );
    
    f_rsp_client_cleanup();
    setverdict(pass);
}

