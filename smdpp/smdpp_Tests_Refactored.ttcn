/* AuthenticateClient Retry Test Case */

function f_TC_AuthenticateClient_RetryCases_Reuse_OTPK(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: AuthenticateClient Retry - Reuse OTPK ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* First InitiateAuthentication */
    var InitiateAuthenticationOkEs9 authOk1 := f_initiateAuthentication();
    g_transactionId := authOk1.transactionId;
    g_serverChallenge := authOk1.serverSigned1.serverChallenge;
    
    /* First AuthenticateClient */
    var RemoteProfileProvisioningRequest authClientReq1 := f_create_authenticate_client_request();
    var RemoteProfileProvisioningResponse authClientResp1 := f_es9p_transceive_success(authClientReq1);
    
    /* GetBoundProfilePackage */
    var AuthenticateClientOk authClientOk1 := authClientResp1.authenticateClientResponse.authenticateClientOk;
    var octetstring smdpSignature2 := authClientOk1.profileMetaData.smdpSigned2.smdpSignature2;
    var PrepareDownloadResponse prepareDownloadResp := f_create_prepare_download_response(smdpSignature2);
    var RemoteProfileProvisioningRequest gbppRequest := f_create_get_bound_profile_package_request(smdpSignature2);
    gbppRequest.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp;
    var RemoteProfileProvisioningResponse gbppResponse := f_es9p_transceive_success(gbppRequest);
    
    /* Second InitiateAuthentication */
    var InitiateAuthenticationOkEs9 authOk2 := f_initiateAuthentication();
    g_transactionId := authOk2.transactionId;
    g_serverChallenge := authOk2.serverSigned1.serverChallenge;
    
    /* Second AuthenticateClient with same OTPK (not regenerated) */
    var RemoteProfileProvisioningRequest authClientReq2 := f_create_authenticate_client_request();
    var RemoteProfileProvisioningResponse authClientResp2 := f_es9p_transceive_success(authClientReq2);
    
    /* Second GetBoundProfilePackage */
    var AuthenticateClientOk authClientOk2 := authClientResp2.authenticateClientResponse.authenticateClientOk;
    var PrepareDownloadResponse prepareDownloadResp2 := f_create_prepare_download_response(authClientOk2.profileMetaData.smdpSigned2.smdpSignature2);
    var RemoteProfileProvisioningRequest gbppRequest2 := f_create_get_bound_profile_package_request(authClientOk2.profileMetaData.smdpSigned2.smdpSignature2);
    gbppRequest2.getBoundProfilePackageRequest.prepareDownloadResponse := prepareDownloadResp2;
    var RemoteProfileProvisioningResponse gbppResponse2 := f_es9p_transceive_success(gbppRequest2);
    
    ext_logInfo("Test passed - Retry with reused OTPK successful");
    f_rsp_client_cleanup();
    setverdict(pass);
}

