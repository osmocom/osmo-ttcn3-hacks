/* InitiateAuthentication Test Cases */

function f_TC_InitiateAuth_01_Nominal(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: InitiateAuthentication - Nominal ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    var RemoteProfileProvisioningRequest authRequest := f_create_initiate_authentication_request();
    var RemoteProfileProvisioningResponse authResponse := f_es9p_transceive_success(authRequest);
    var InitiateAuthenticationOkEs9 authOk := authResponse.initiateAuthenticationResponse.initiateAuthenticationOk;
    
    /* Validate transaction ID consistency */
    if (authOk.transactionId != authOk.serverSigned1.transactionId) {
        setverdict(fail, "Transaction ID mismatch between response and serverSigned1");
        f_rsp_client_cleanup();
        return;
    }
    
    /* TODO: Verify server signature - would need crypto implementation */
    
    /* Validate euiccCiPKIdToBeUsed is in the provided list */
    var boolean pkid_found := false;
    for (var integer i := 0; i < lengthof(authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning); i := i + 1) {
        if (authOk.euiccCiPKIdToBeUsed == authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning[i]) {
            pkid_found := true;
            break;
        }
    }
    if (not pkid_found) {
        setverdict(fail, "euiccCiPKIdToBeUsed not found in euiccCiPKIdListForSigning");
        f_rsp_client_cleanup();
        return;
    }
    
    ext_logInfo("Test passed - InitiateAuthentication nominal flow successful");
    f_rsp_client_cleanup();
    setverdict(pass);
}

function f_TC_InitiateAuth_02_Uniqueness(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: InitiateAuthentication - Uniqueness ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* First request */
    var RemoteProfileProvisioningRequest authRequest1 := f_create_initiate_authentication_request();
    var RemoteProfileProvisioningResponse authResponse1 := f_es9p_transceive_success(authRequest1);
    var octetstring transactionId1 := authResponse1.initiateAuthenticationResponse.initiateAuthenticationOk.transactionId;
    var octetstring serverChallenge1 := authResponse1.initiateAuthenticationResponse.initiateAuthenticationOk.serverSigned1.serverChallenge;
    
    /* Store first values */
    g_transactionId := transactionId1;
    g_serverChallenge := serverChallenge1;
    
    /* Second request with same euiccChallenge */
    var RemoteProfileProvisioningRequest authRequest2 := f_create_initiate_authentication_request();
    authRequest2.initiateAuthenticationRequest.euiccChallenge := authRequest1.initiateAuthenticationRequest.euiccChallenge;
    var RemoteProfileProvisioningResponse authResponse2 := f_es9p_transceive_success(authRequest2);
    var octetstring transactionId2 := authResponse2.initiateAuthenticationResponse.initiateAuthenticationOk.transactionId;
    var octetstring serverChallenge2 := authResponse2.initiateAuthenticationResponse.initiateAuthenticationOk.serverSigned1.serverChallenge;
    
    /* Verify uniqueness */
    if (transactionId1 == transactionId2) {
        setverdict(fail, "Transaction IDs are not unique");
    } else if (serverChallenge1 == serverChallenge2) {
        setverdict(fail, "Server challenges are not unique");
    } else {
        ext_logInfo("Test passed - Transaction IDs and server challenges are unique");
        setverdict(pass);
    }
    
    f_rsp_client_cleanup();
}

function f_TC_InitiateAuth_03_InvalidServerAddress(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: InitiateAuthentication - Invalid Server Address ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    var RemoteProfileProvisioningRequest authRequest := f_create_initiate_authentication_request();
    authRequest.initiateAuthenticationRequest.smdpAddress := omit;
    
    var RemoteProfileProvisioningResponse authResponse := f_es9p_transceive_error(authRequest);
    
    if (ispresent(authResponse.initiateAuthenticationResponse.initiateAuthenticationError)) {
        var JSON_ES9p_initiateAuthenticationError error_data := authResponse.initiateAuthenticationResponse.initiateAuthenticationError;
        ext_logInfo("Received expected error - subjectCode: " & error_data.subjectCode & ", reasonCode: " & error_data.reasonCode);
        setverdict(pass);
    } else {
        setverdict(fail, "Expected error response but got success");
    }
    
    f_rsp_client_cleanup();
}

/* AuthenticateClient Test Cases */

function f_TC_AuthenticateClient_01_Nominal(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: AuthenticateClient - Nominal ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* Perform initial authentication to get transaction context */
    var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
    
    /* Store transaction ID and server challenge */
    g_transactionId := authOk.transactionId;
    g_serverChallenge := authOk.serverSigned1.serverChallenge;
    
    /* AuthenticateClient */
    var RemoteProfileProvisioningRequest authClientReq := f_create_authenticate_client_request();
    var RemoteProfileProvisioningResponse authClientResp := f_es9p_transceive_success(authClientReq);
    var AuthenticateClientOk authClientOk := authClientResp.authenticateClientResponse.authenticateClientOk;
    
    /* Verify transaction ID consistency */
    if (authClientOk.transactionId != g_transactionId) {
        setverdict(fail, "Transaction ID mismatch in AuthenticateClient response");
        f_rsp_client_cleanup();
        return;
    }
    
    ext_logInfo("Test passed - AuthenticateClient successful");
    f_rsp_client_cleanup();
    setverdict(pass);
}

function f_TC_AuthenticateClient_02_ConfirmationCode(charstring id) runs on smdpp_ConnHdlr {
    ext_logInfo("=== Test Case: AuthenticateClient - With Confirmation Code ===");
    
    if (not f_rsp_client_init()) {
        setverdict(fail, "RSP client initialization failed");
        return;
    }
    
    /* InitiateAuthentication */
    var InitiateAuthenticationOkEs9 authOk := f_initiateAuthentication();
    g_transactionId := authOk.transactionId;
    g_serverChallenge := authOk.serverSigned1.serverChallenge;
    
    /* AuthenticateClient with confirmation code */
    var RemoteProfileProvisioningRequest authClientReq := f_create_authenticate_client_request();
    authClientReq.authenticateClientRequest.confirmationCode := ts_confirmationCodeChoice(required);
    var RemoteProfileProvisioningResponse authClientResp := f_es9p_transceive_success(authClientReq);
    
    /* Verify confirmation code was requested */
    if (not ispresent(authClientResp.authenticateClientResponse.authenticateClientOk.confirmationCodeRequired)) {
        setverdict(fail, "Confirmation code not requested when expected");
        f_rsp_client_cleanup();
        return;
    }
    
    ext_logInfo("Test passed - Confirmation code requested as expected");
    f_rsp_client_cleanup();
    setverdict(pass);
}

