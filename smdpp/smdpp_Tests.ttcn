/* RSP Protocol Constants */
const charstring c_oid_rspRole_dp_auth := "2.23.146.1.2.1.4";
const charstring c_oid_rspRole_dp_pb := "2.23.146.1.2.1.5";

/* Protocol Operation IDs */
const integer c_remoteOpId_installBoundProfilePackage := 1;

/* Cryptographic Constants */
const octetstring c_keyType_AES := '88'O;
const octetstring c_keyLen_16bytes := '10'O;
const octetstring c_ecPoint_uncompressed := '04'O;

/* Validation Limits */
const integer c_hostId_min_length := 4;
const integer c_hostId_max_length := 16;
const integer c_min_segment_length := 2;

/* ============================================================================
 * TTCN-3 COMPONENT TYPES
 * ============================================================================ */

type component MTC_CT {
	timer g_Tguard;
	var HTTP_Server_Emulation_CT vc_HTTP_es12;
	var HTTP_Server_Emulation_CT vc_HTTP_es2p;
};

type component smdpp_ConnHdlr extends HTTP_ConnHdlr, http_CT {
	var smdpp_ConnHdlrPars g_pars_smdpp;
	var template integer g_http_client_id_es9p := omit;
	var template integer g_http_client_id_es2p := omit;

	/* C++ RSP client handle */
	var integer g_rsp_client_handle := -1;

	/* Session state */
	var octetstring g_transactionId := ''O;
	var octetstring g_euiccChallenge := ''O;
	var octetstring g_serverChallenge := ''O;
	var octetstring g_serverCert := ''O;
	var boolean g_authenticationComplete := false;
};

type record smdpp_ConnHdlrPars {
	charstring smdp_server_url,
	integer smdp_server_port,
	charstring cert_path,
	charstring cert_name_filter,
	charstring euicc_cert_path,
	charstring euicc_key_path
};

private function f_init_pars() runs on MTC_CT return smdpp_ConnHdlrPars {
	var smdpp_ConnHdlrPars pars := {
		smdp_server_url := "testsmdpplus1.example.com",
		smdp_server_port := 8000,
		cert_path := "./sgp26/CertificateIssuer",
		cert_name_filter := "NIST",
		euicc_cert_path := "./sgp26/eUICC/CERT_EUICC_ECDSA_NIST.der",
		euicc_key_path := "./sgp26/eUICC/SK_EUICC_ECDSA_NIST.pem"
	};
	return pars;
}

modulepar {
	HTTP_Adapter_Params mp_es9p_client := {
		http_host := "127.0.0.1",
		http_port := 8000,
		use_ssl := true
	};

	HTTP_Adapter_Params mp_es2p_client := {
		http_host := "127.0.0.1",
		http_port := 8001,
		use_ssl := true
	};

	HttpServerEmulationCfg mp_es12_server := {
		http_bind_ip := "127.0.0.1",
		http_bind_port := 8002,
		use_ssl := false
	};

	HttpServerEmulationCfg mp_es2p_server := {
		http_bind_ip := "127.0.0.1",
		http_bind_port := 8003,
		use_ssl := false
	};
}

private altstep as_Tguard() runs on MTC_CT {
	[] g_Tguard.timeout {
		Misc_Helpers.f_shutdown(__BFILE__, __LINE__, fail, "Tguard timeout");
	}
}

private type function void_fn(charstring id) runs on smdpp_ConnHdlr;

private function f_init_handler(void_fn fn, charstring id, smdpp_ConnHdlrPars pars) runs on smdpp_ConnHdlr {
	g_pars_smdpp := pars;
	fn.apply(id);
}

private function f_start_handler(void_fn fn, smdpp_ConnHdlrPars pars)
runs on MTC_CT return smdpp_ConnHdlr {
	var smdpp_ConnHdlr vc_conn;
	var charstring id := testcasename();

	vc_conn := smdpp_ConnHdlr.create(id);

	if (isbound(vc_HTTP_es12)) {
		connect(vc_conn:HTTP_SRV[0], vc_HTTP_es12:CLIENT);
		connect(vc_conn:HTTP_SRV_PROC[0], vc_HTTP_es12:CLIENT_PROC);
	}

	if (isbound(vc_HTTP_es2p)) {
		connect(vc_conn:HTTP_SRV[1], vc_HTTP_es2p:CLIENT);
		connect(vc_conn:HTTP_SRV_PROC[1], vc_HTTP_es2p:CLIENT_PROC);
	}

	vc_conn.start(f_init_handler(fn, id, pars));
	return vc_conn;
}

private function f_init(charstring id, float t_guard := 60.0) runs on MTC_CT {
	g_Tguard.start(t_guard);
	activate(as_Tguard());

	vc_HTTP_es12 := HTTP_Server_Emulation_CT.create(id);
	vc_HTTP_es12.start(HTTP_Server_Emulation.main(mp_es12_server));

	vc_HTTP_es2p := HTTP_Server_Emulation_CT.create(id);
	vc_HTTP_es2p.start(HTTP_Server_Emulation.main(mp_es2p_server));
}

/* ============================================================================
 * RSP CLIENT WRAPPER FUNCTIONS
 * ============================================================================ */

private function f_rsp_client_init() runs on smdpp_ConnHdlr return boolean {
	ext_logInfo("Initializing RSP client");

	g_rsp_client_handle := ext_RSPClient_create(
		g_pars_smdpp.smdp_server_url,
		g_pars_smdpp.smdp_server_port,
		g_pars_smdpp.cert_path,
		g_pars_smdpp.cert_name_filter
	);

	if (g_rsp_client_handle < 0) {
		ext_logError("Failed to create RSP client");
		return false;
	}

	if (ext_RSPClient_loadEUICCCertificate(g_rsp_client_handle, g_pars_smdpp.euicc_cert_path) != 0) {
		ext_logError("Failed to load eUICC certificate");
		f_rsp_client_cleanup();
		return false;
	}

	if (ext_RSPClient_loadEUICCKeyPair(g_rsp_client_handle, g_pars_smdpp.euicc_key_path) != 0) {
		ext_logError("Failed to load eUICC private key");
		f_rsp_client_cleanup();
		return false;
	}

	ext_logInfo("RSP client initialized with handle: " & int2str(g_rsp_client_handle));
	return true;
}

private function f_rsp_client_cleanup() runs on smdpp_ConnHdlr {
	if (g_rsp_client_handle >= 0) {
		ext_RSPClient_destroy(g_rsp_client_handle);
		g_rsp_client_handle := -1;
	}
}

/* ============================================================================
 * RSP PROTOCOL IMPLEMENTATION
 * ============================================================================ */

private function f_create_initiate_authentication_request() runs on smdpp_ConnHdlr
return RemoteProfileProvisioningRequest {

	/* Generate eUICC challenge using C++ crypto */
	g_euiccChallenge := ext_RSPClient_generateChallenge(g_rsp_client_handle);
	ext_logInfo("Generated eUICC challenge: " & ext_bytesToHex(g_euiccChallenge));

	/* Create EUICC_INFO1 using TTCN-3 native types */
	var EUICCInfo1 euiccInfo1 := {
		svn := '020200'O, /* SGP.22 v2.2.0 */
		euiccCiPKIdListForVerification := {
			ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
			ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
		},
		euiccCiPKIdListForSigning := {
			ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
			ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
		}
	};

	/* Create the request structure */
	var RemoteProfileProvisioningRequest request := {
		initiateAuthenticationRequest := {
			euiccChallenge := g_euiccChallenge,
			smdpAddress := g_pars_smdpp.smdp_server_url,
			euiccInfo1 := euiccInfo1
		}
	};

	ext_logInfo("Created initiateAuthentication request");
	return request;
}

private function f_validate_initiate_authentication_response(RemoteProfileProvisioningResponse response)
runs on smdpp_ConnHdlr return boolean {

	if (not ispresent(response.initiateAuthenticationResponse)) {
		ext_logError("No initiateAuthenticationResponse in response");
		return false;
	}

	if (not ispresent(response.initiateAuthenticationResponse.initiateAuthenticationOk)) {
		ext_logError("Authentication failed - no OK response");
		return false;
	}

	var InitiateAuthenticationOkEs9 authOk := response.initiateAuthenticationResponse.initiateAuthenticationOk;

	/* Store session data */
	g_transactionId := authOk.transactionId;
	g_serverCert := enc_Certificate(authOk.serverCertificate);

	ext_logInfo("Received transaction ID: " & ext_bytesToHex(g_transactionId));

	/* Validate transaction ID match */
	if (authOk.serverSigned1.transactionId != g_transactionId) {
		ext_logError("Transaction ID mismatch");
		return false;
	}

	/* Validate eUICC challenge match */
	if (authOk.serverSigned1.euiccChallenge != g_euiccChallenge) {
		ext_logError("eUICC challenge mismatch");
		return false;
	}

	/* Store server challenge */
	g_serverChallenge := authOk.serverSigned1.serverChallenge;

	// log(authOk);
	/* Validate server signature using C++ crypto */
	if (not ext_RSPClient_verifyServerSignature(g_rsp_client_handle, enc_ServerSigned1(authOk.serverSigned1), authOk.serverSignature1, g_serverCert)) {
		ext_logError("Server signature validation failed");
		return false;
	}

	ext_logInfo("Authentication response validation successful");
	g_authenticationComplete := true;
	return true;
}

private function f_create_get_bound_profile_package_request(octetstring smdpSignature2) runs on smdpp_ConnHdlr
return RemoteProfileProvisioningRequest {

	// if (not g_authenticationComplete) {
	// 	ext_logError("Authentication not complete");
	// 	return omit;
	// }

	/* Generate eUICC one-time public key using C++ crypto */
	var octetstring euiccOtpk := ext_RSPClient_generateEUICCOtpk(g_rsp_client_handle);

	/* Create EUICC_SIGNED2 using TTCN-3 native types */
	var EUICCSigned2 euiccSigned2 := {
		transactionId := g_transactionId,
		euiccOtpk := euiccOtpk,
		hashCc := omit
	};

	var octetstring euiccSigned2Data := enc_EUICCSigned2(euiccSigned2);
	var octetstring concatdata := euiccSigned2Data & smdpSignature2;
	var octetstring euiccSignature2 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, concatdata);

	/* Create PrepareDownloadResponse */
	var PrepareDownloadResponse prepareDownloadResponse := {
		downloadResponseOk := {
			euiccSigned2 := euiccSigned2,
			euiccSignature2 := euiccSignature2
		}
	};

	/* Create the request */
	var RemoteProfileProvisioningRequest request := {
		getBoundProfilePackageRequest := {
			transactionId := g_transactionId,
			prepareDownloadResponse := prepareDownloadResponse
		}
	};

	ext_logInfo("Created getBoundProfilePackage request");
	return request;
}

private function f_validate_get_bound_profile_package_response(RemoteProfileProvisioningResponse response)
runs on smdpp_ConnHdlr return boolean {

	if (not ispresent(response.getBoundProfilePackageResponse)) {
		ext_logError("No getBoundProfilePackageResponse in response");
		return false;
	}

	if (not ispresent(response.getBoundProfilePackageResponse.getBoundProfilePackageOk)) {
		ext_logError("getBoundProfilePackage failed - no OK response");
		return false;
	}

	var GetBoundProfilePackageOk packageOk := response.getBoundProfilePackageResponse.getBoundProfilePackageOk;

	/* Validate transaction ID match */
	if (packageOk.transactionId != g_transactionId or packageOk.boundProfilePackage.initialiseSecureChannelRequest.transactionId != g_transactionId) {
		ext_logError("Transaction ID mismatch in getBoundProfilePackage response");
		return false;
	}

	if (not ispresent(packageOk.boundProfilePackage)) {
		ext_logError("No boundProfilePackage in response");
		return false;
	}

	/* Decode BoundProfilePackage using TTCN-3 native decoder */
	var BoundProfilePackage boundPackage := packageOk.boundProfilePackage;

	/* Validate structure */
	if (not ispresent(boundPackage.initialiseSecureChannelRequest)) {
		ext_logError("Missing initialiseSecureChannelRequest");
		return false;
	}

	if (not ispresent(boundPackage.firstSequenceOf87)) {
		ext_logError("Missing firstSequenceOf87");
		return false;
	}

	if (not ispresent(boundPackage.sequenceOf88)) {
		ext_logError("Missing sequenceOf88");
		return false;
	}

	if (not ispresent(boundPackage.sequenceOf86)) {
		ext_logError("Missing sequenceOf86");
		return false;
	}

	ext_logInfo("getBoundProfilePackage response validation successful");
	return true;
}

/* ============================================================================
 * HTTP COMMUNICATION
 * ============================================================================ */

template (value) HeaderLines ts_rsp_HTTP_Header := {
	{ header_name := "User-Agent", header_value := "TTCN3 smdpp testsuite" },
	{ header_name := "X-Admin-Protocol", header_value := "gsma/rsp/v2.5.0" },
	{ header_name := "Content-Type", header_value := "application/json;charset=UTF-8" }
};

/* Send ES9+ HTTP request */
private function f_es9p_send(RemoteProfileProvisioningRequest es9p_req) runs on smdpp_ConnHdlr {
	var charstring es9p_req_enc;
	var charstring es9p_url;

	if (ispresent(es9p_req.initiateAuthenticationRequest)) {
		es9p_url := "/gsma/rsp2/es9plus/initiateAuthentication";
	} else if (ispresent(es9p_req.getBoundProfilePackageRequest)) {
		es9p_url := "/gsma/rsp2/es9plus/getBoundProfilePackage";
	} else if (ispresent(es9p_req.authenticateClientRequest)) {
		es9p_url := "/gsma/rsp2/es9plus/authenticateClient";
	} else if (ispresent(es9p_req.handleNotification)) {
		es9p_url := "/gsma/rsp2/es9plus/handleNotification";
	} else if (ispresent(es9p_req.cancelSessionRequestEs9)) {
		es9p_url := "/gsma/rsp2/es9plus/cancelSession";
	} else {
		setverdict(fail, "unknown JSON ES9+ function");
	}

	enc_RemoteProfileProvisioningRequest_to_JSON(es9p_req, es9p_req_enc);

	f_http_tx_request(url := es9p_url,
			  method := "POST",
			  body := es9p_req_enc,
			  custom_hdr := valueof(ts_rsp_HTTP_Header),
			  client_id := g_http_client_id_es9p,
			  http_pars := mp_es9p_client);
}

/* Receive ES9+ HTTP response */
private function f_es9p_receive(template RemoteProfileProvisioningResponse expected_es9p_res := omit)
runs on smdpp_ConnHdlr return template RemoteProfileProvisioningResponse {
	var RemoteProfileProvisioningResponse es9p_res;
	var HTTPMessage response_http;
	response_http := f_http_rx_response(exp := ?,
					    client_id := g_http_client_id_es9p,
					    keep_connection := true);

	if (istemplatekind(g_http_client_id_es9p, "omit")) {
		/* Memorize client_id of the first request. The client_id will identify the HTTP connection
		 * in all consecutive requests. */
		g_http_client_id_es9p := f_http_client_id_from_http_response(response_http);
	} else if (valueof(g_http_client_id_es9p) != valueof(f_http_client_id_from_http_response(response_http))) {
		/* The client_id must not change. A sudden change of the client_id may indicate an interrupted
		 * HTTP connection. This must not happen unexpectetly. */
		setverdict(fail, "unexpected ES9+ HTTP connection");
	}

	log("Response HTTP structure received");
	if (ispresent(response_http.response)) {
		log("HTTP response is present");
		log("HTTP response body present: ", ispresent(response_http.response.body));
		if (ispresent(response_http.response.body)) {
			log("HTTP response body length: ", lengthof(response_http.response.body));
			// Print first 200 chars to avoid log overflow
			if (lengthof(response_http.response.body) > 0) {
				var integer max_len := 200;
				if (lengthof(response_http.response.body) < max_len) {
					max_len := lengthof(response_http.response.body);
				}
				log("HTTP response body (first ", max_len, " chars): ", substr(response_http.response.body, 0, max_len));
			} else {
				log("HTTP response body is EMPTY (zero length)!");
			}
		} else {
			log("ERROR: No HTTP response body");
			setverdict(fail, "No HTTP response body");
			return omit;
		}
		log("About to call JSON decoder with body of length: ", lengthof(response_http.response.body));
		dec_RemoteProfileProvisioningResponse_from_JSON(response_http.response.body, es9p_res);
		if (not istemplatekind(expected_es9p_res, "omit")) {
			if (not match(es9p_res, expected_es9p_res)) {
				setverdict(fail, "unexpected response from SM-DP+ on ES9+");
			}
		}

		if (isvalue(es9p_res)) {
			return es9p_res;
		}
		return omit
	} else {
		setverdict(fail,
			   "unexpected ES9+ response, the HTTP body did either contain no or a non binary response");
		return omit;
	}
}

/* Perform one ES9+ HTTP request/response cycle */
private function f_es9p_client_transceive(RemoteProfileProvisioningRequest es9p_req,
					  template RemoteProfileProvisioningResponse expected_es9p_res := omit)
runs on smdpp_ConnHdlr return template RemoteProfileProvisioningResponse {
	var template RemoteProfileProvisioningResponse es9p_res
	f_es9p_send(es9p_req);
	es9p_res := f_es9p_receive();
	if (not istemplatekind(expected_es9p_res, "omit")) {
		if (not match(valueof(es9p_res), expected_es9p_res)) {
			setverdict(fail, "unexpected response from SM-DP+ on ES9+");
		}
	}
	return es9p_res;
}


private function f_send_es9p_request(charstring endpoint, charstring jsonBody) runs on smdpp_ConnHdlr return charstring {
	f_http_tx_request(url := endpoint,
	                  method := "POST",
	                  body := jsonBody,
	                  custom_hdr := valueof(ts_rsp_HTTP_Header),
	                  client_id := g_http_client_id_es9p,
	                  http_pars := mp_es9p_client);

	var HTTPMessage response_http := f_http_rx_response(exp := ?,
	                                                   client_id := g_http_client_id_es9p,
	                                                   keep_connection := true);

	if (istemplatekind(g_http_client_id_es9p, "omit")) {
		g_http_client_id_es9p := f_http_client_id_from_http_response(response_http);
	}

	if (ispresent(response_http.response) and response_http.response.statuscode == 200) {
		ext_logInfo("HTTP " & int2str(response_http.response.statuscode) &
		           " response, body length: " & int2str(lengthof(response_http.response.body)));
		return response_http.response.body;
	} else {
		if (ispresent(response_http.response)) {
			ext_logError("HTTP error response: " & int2str(response_http.response.statuscode));
		} else {
			ext_logError("No HTTP response");
		}
		return "";
	}
}

private function f_perform_es9p_request_response(RemoteProfileProvisioningRequest request,
                                               charstring endpoint) runs on smdpp_ConnHdlr
return RemoteProfileProvisioningResponse {

	/* Encode request to JSON */
	var charstring requestJson;
	enc_RemoteProfileProvisioningRequest_to_JSON(request, requestJson);

	ext_logInfo("Sending " & endpoint & " request");
	ext_logDebug("Request JSON length: " & int2str(lengthof(requestJson)));

	/* Send HTTP request */
	var charstring responseJson := f_send_es9p_request(endpoint, requestJson);

	// if (lengthof(responseJson) == 0) {
	// 	ext_logError("Empty response received");
	// 	return omit;
	// }

	/* Decode JSON response */
	var RemoteProfileProvisioningResponse response;
	dec_RemoteProfileProvisioningResponse_from_JSON(responseJson, response);

	return response;
}

/* ============================================================================
 * TEST CASE IMPLEMENTATIONS
 * ============================================================================ */

function to_upper(in charstring str) return charstring {
    return f_str_toupper(str);
}


private function enc_InitialiseSecureChannelRequest(InitialiseSecureChannelRequest req) return octetstring {
    // This is a simplified encoding - real implementation needs proper BER-TLV
    var octetstring result := 'BF23'O; // Tag [35]

    // Encode content
    var octetstring content := ''O;

    // remoteOpId [2]
    content := content & '8201'O & int2oct(req.remoteOpId, 1);

    // transactionId [0]
    content := content & '80'O & int2oct(lengthof(req.transactionId), 1) & req.transactionId;

    // controlRefTemplate [6] IMPLICIT
    var octetstring crt := req.controlRefTemplate.keyType &
                          req.controlRefTemplate.keyLen &
                          '84'O & int2oct(lengthof(req.controlRefTemplate.hostId), 1) &
                          req.controlRefTemplate.hostId;
    content := content & 'A6'O & int2oct(lengthof(crt), 1) & crt;

    // smdpOtpk [APPLICATION 73]
    content := content & '5F49'O & int2oct(lengthof(req.smdpOtpk), 1) & req.smdpOtpk;

    // Length encoding
    if (lengthof(content) < 128) {
        result := result & int2oct(lengthof(content), 1) & content;
    } else {
        // Long form
        var integer len := lengthof(content);
        var octetstring lenOct := int2oct(len, 2);
        result := result & '82'O & lenOct & content;
    }

    return result;
}

private function f_validate_ber_tlv_structure(octetstring data, integer expected_tag) runs on smdpp_ConnHdlr
return boolean {
    // Basic BER-TLV validation for APDU command structures
    if (lengthof(data) < 2) {
        ext_logError("BER-TLV data too small - missing tag/length");
        return false;
    }

    // Check if the tag matches expected value
    var integer tag := oct2int(data[0]);
    if (tag != expected_tag) {
        ext_logError("BER-TLV tag mismatch - expected " & int2str(expected_tag) & ", got " & int2str(tag));
        return false;
    }

    // Basic length field validation
    var integer length_byte := oct2int(data[1]);
    if (length_byte < 128) {
        // Short form length (bit 7 = 0)
        if (lengthof(data) < 2 + length_byte) {
            ext_logError("BER-TLV short form length inconsistent with data size");
            return false;
        }
    } else {
        // Long form length (bit 7 = 1)
        var integer num_octets := length_byte - 128;
        if (num_octets == 0 or num_octets > 4) {
            ext_logError("BER-TLV invalid long form length encoding");
            return false;
        }
        if (lengthof(data) < 2 + num_octets) {
            ext_logError("BER-TLV long form length incomplete");
            return false;
        }
    }

    ext_logDebug("BER-TLV structure validation passed for tag " & int2str(tag));
    return true;
}

/* Helper function to validate ConfigureISDP segments */
private function f_validate_configure_isdp_segments(BoundProfilePackage bpp,
                                                   octetstring sEnc,
                                                   octetstring sMac) runs on smdpp_ConnHdlr
return boolean {
    for (var integer i := 0; i < lengthof(bpp.firstSequenceOf87); i := i + 1) {
        var octetstring segment := bpp.firstSequenceOf87[i];

        if (lengthof(segment) < 1) {
            ext_logError("Invalid ConfigureISDP segment - empty data");
            return false;
        }

        ext_logInfo("ConfigureISDP segment " & int2str(i) &
                   " - performing cryptographic validation (" & int2str(lengthof(segment)) & " bytes)");

        // Perform actual cryptographic validation using session keys
        if (not ext_Crypto_verifyEncryptedProfileData(segment, sEnc, sMac)) {
            ext_logError("ConfigureISDP segment " & int2str(i) & " cryptographic validation failed");
            return false;
        }

        ext_logInfo("ConfigureISDP segment " & int2str(i) & " validated successfully");
    }
    return true;
}

/* Helper function to validate StoreMetadata segments */
private function f_validate_store_metadata_segments(BoundProfilePackage bpp,
                                                   octetstring sEnc,
                                                   octetstring sMac) runs on smdpp_ConnHdlr
return boolean {
    for (var integer i := 0; i < lengthof(bpp.sequenceOf88); i := i + 1) {
        var octetstring segment := bpp.sequenceOf88[i];

        if (lengthof(segment) < 1) {
            ext_logError("Invalid StoreMetadata segment - empty data");
            return false;
        }

        ext_logInfo("StoreMetadata segment " & int2str(i) &
                   " - performing cryptographic validation (" & int2str(lengthof(segment)) & " bytes)");

        // Perform actual cryptographic validation using session keys
        if (not ext_Crypto_verifyEncryptedProfileData(segment, sEnc, sMac)) {
            ext_logError("StoreMetadata segment " & int2str(i) & " cryptographic validation failed");
            return false;
        }

        ext_logInfo("StoreMetadata segment " & int2str(i) & " validated successfully");
    }
    return true;
}

/* Helper function to validate LoadProfileElements segments */
private function f_validate_load_profile_elements_segments(BoundProfilePackage bpp,
                                                          octetstring sEnc,
                                                          octetstring sMac) runs on smdpp_ConnHdlr
return boolean {
    for (var integer i := 0; i < lengthof(bpp.sequenceOf86); i := i + 1) {
        var octetstring segment := bpp.sequenceOf86[i];

        if (lengthof(segment) < 1) {
            ext_logError("Invalid LoadProfileElements segment - empty data");
            return false;
        }

        ext_logInfo("LoadProfileElements segment " & int2str(i) &
                   " - performing cryptographic validation (" & int2str(lengthof(segment)) & " bytes)");

        // Perform actual cryptographic validation using session keys
        if (not ext_Crypto_verifyEncryptedProfileData(segment, sEnc, sMac)) {
            ext_logError("LoadProfileElements segment " & int2str(i) & " cryptographic validation failed");
            return false;
        }

        ext_logInfo("LoadProfileElements segment " & int2str(i) & " validated successfully");
    }
    return true;
}

/* Validate all profile segments in BoundProfilePackage */
private function f_validate_profile_segments(BoundProfilePackage bpp,
                                           octetstring sEnc,
                                           octetstring sMac) runs on smdpp_ConnHdlr
return boolean {
    ext_logInfo("=== Validating encrypted profile segments ===");

    // Validate firstSequenceOf87 (ConfigureISDP) - Encrypted BER-TLV APDU commands
    if (not f_validate_configure_isdp_segments(bpp, sEnc, sMac)) {
        return false;
    }

    // Validate sequenceOf88 (StoreMetadata) - Encrypted BER-TLV APDU commands
    if (not f_validate_store_metadata_segments(bpp, sEnc, sMac)) {
        return false;
    }

    // Validate sequenceOf86 (LoadProfileElements) - Encrypted BER-TLV APDU commands
    if (not f_validate_load_profile_elements_segments(bpp, sEnc, sMac)) {
        return false;
    }

    ext_logInfo("All profile segments cryptographically validated successfully");
    return true;
}


external function encode_DER_InitialiseSecureChannelRequest_ver(
  in InitialiseSecureChannelRequest_ver pdu
) return octetstring
with { extension "prototype(convert) encode(BER:BER_ENCODE_DER)" };

/* ============================================================================
 * VALIDATION HELPER FUNCTIONS
 * ============================================================================ */

/* Validate InitialiseSecureChannelRequest structure */
private function f_validate_initialise_secure_channel_request(InitialiseSecureChannelRequest iscReq)
runs on smdpp_ConnHdlr return boolean {
    // 1. RemoteOpId must be installBoundProfilePackage (1)
    if (iscReq.remoteOpId != c_remoteOpId_installBoundProfilePackage) {
        ext_logError("Invalid remoteOpId, expected installBoundProfilePackage(" &
                    int2str(c_remoteOpId_installBoundProfilePackage) & ")");
        return false;
    }

    // 2. Validate ControlRefTemplate
    if (iscReq.controlRefTemplate.keyType != c_keyType_AES) {
        ext_logError("Invalid key type, expected AES (0x88)");
        return false;
    }

    if (iscReq.controlRefTemplate.keyLen != c_keyLen_16bytes) {
        ext_logError("Invalid key length, expected 16 bytes (0x10)");
        return false;
    }

    if (lengthof(iscReq.controlRefTemplate.hostId) < c_hostId_min_length or
        lengthof(iscReq.controlRefTemplate.hostId) > c_hostId_max_length) {
        ext_logError("Invalid hostId length (" & int2str(lengthof(iscReq.controlRefTemplate.hostId)) &
                    "), expected " & int2str(c_hostId_min_length) & "-" & int2str(c_hostId_max_length));
        return false;
    }

    // 3. Verify smdpOtpk is present and valid EC public key
    if (not ispresent(iscReq.smdpOtpk) or lengthof(iscReq.smdpOtpk) == 0) {
        ext_logError("Missing or empty smdpOtpk");
        return false;
    }

    // Check it's an uncompressed EC point
    if (iscReq.smdpOtpk[0] != c_ecPoint_uncompressed) {
        ext_logError("smdpOtpk is not an uncompressed EC point");
        return false;
    }

    return true;
}

/* Validate ECDH compatibility and signature */
private function f_validate_ecdh_and_signature(InitialiseSecureChannelRequest iscReq,
                                             AuthenticateClientOk auok,
                                             RemoteProfileProvisioningRequest packageRequest)
runs on smdpp_ConnHdlr return boolean {
    // 1. Verify ECDH compatibility between eUICC and SM-DP+ public keys
    var octetstring euiccOtpk := ext_RSPClient_getEUICCOtpk(g_rsp_client_handle);
    if (not ext_CertificateUtil_verifyECDHCompatible(euiccOtpk, iscReq.smdpOtpk)) {
        ext_logError("eUICC and SM-DP+ public keys are not ECDH compatible");
        return false;
    }

    // 2. Verify InitialiseSecureChannelRequest signature
    var InitialiseSecureChannelRequest_ver toencsec := {
        remoteOpId := c_remoteOpId_installBoundProfilePackage,
        transactionId := g_transactionId,
        controlRefTemplate := iscReq.controlRefTemplate,
        smdpOtpk := iscReq.smdpOtpk,
        euiccOtpk := packageRequest.getBoundProfilePackageRequest.prepareDownloadResponse.downloadResponseOk.euiccSigned2.euiccOtpk
    };

    var octetstring encsecr := encode_DER_InitialiseSecureChannelRequest_ver(toencsec);
    var octetstring trunc_initsec := substr(encsecr, 4, lengthof(encsecr)-4);

    if (not ext_RSPClient_verifyServerSignature(g_rsp_client_handle, trunc_initsec,
                                               iscReq.smdpSign, enc_Certificate(auok.smdpCertificate))) {
        ext_logError("InitialiseSecureChannelRequest signature validation failed");
        return false;
    }

    return true;
}

/* Validate BoundProfilePackage structure */
private function f_validate_bound_profile_package_structure(BoundProfilePackage bpp)
runs on smdpp_ConnHdlr return boolean {
    if (not ispresent(bpp.firstSequenceOf87) or lengthof(bpp.firstSequenceOf87) == 0) {
        ext_logError("Missing or empty firstSequenceOf87 (ConfigureISDP)");
        return false;
    }

    if (not ispresent(bpp.sequenceOf88) or lengthof(bpp.sequenceOf88) == 0) {
        ext_logError("Missing or empty sequenceOf88 (StoreMetadata)");
        return false;
    }

    if (not ispresent(bpp.sequenceOf86) or lengthof(bpp.sequenceOf86) == 0) {
        ext_logError("Missing or empty sequenceOf86 (LoadProfileElements)");
        return false;
    }

    return true;
}

/* Helper function for error handling with cleanup */
private function f_fail_and_cleanup(charstring error_msg) runs on smdpp_ConnHdlr {
    ext_logError(error_msg);
    setverdict(fail, error_msg);
    f_rsp_client_cleanup();
}

/* Helper function to validate and derive session keys */
private function f_validate_and_derive_session_keys(octetstring sharedSecret,
                                                   octetstring hostId,
                                                   out octetstring sEnc,
                                                   out octetstring sMac,
                                                   out octetstring sDek) runs on smdpp_ConnHdlr
return boolean {
    // Derive session keys using GlobalPlatform SCP03
    ext_Crypto_deriveSessionKeys(sharedSecret, hostId, sEnc, sMac, sDek);

    // Verify all keys are 16 bytes (AES-128)
    if (lengthof(sEnc) != 16 or lengthof(sMac) != 16 or lengthof(sDek) != 16) {
        ext_logError("Invalid session key lengths");
        return false;
    }

    ext_logInfo("Session keys derived successfully");
    ext_logDebug("S-ENC: " & oct2str(sEnc));
    ext_logDebug("S-MAC: " & oct2str(sMac));
    ext_logDebug("S-DEK: " & oct2str(sDek));

    return true;
}

/* Helper function to validate and derive BSP session keys */
private function f_validate_and_derive_bsp_session_keys(octetstring sharedSecret,
                                                       octetstring hostId,
                                                       octetstring eid,
                                                       out octetstring bspSEnc,
                                                       out octetstring bspSMac,
                                                       out octetstring initialMCV) runs on smdpp_ConnHdlr
return boolean {
    // Derive BSP session keys using X9.63 KDF
    if (not ext_Crypto_deriveBSPSessionKeys(sharedSecret, 136, 16, hostId, eid, bspSEnc, bspSMac, initialMCV)) {
        ext_logError("BSP session key derivation failed");
        return false;
    }

    // Verify all keys are 16 bytes (AES-128)
    if (lengthof(bspSEnc) != 16 or lengthof(bspSMac) != 16 or lengthof(initialMCV) != 16) {
        ext_logError("Invalid BSP session key lengths");
        return false;
    }

    ext_logInfo("BSP session keys derived successfully");
    ext_logDebug("BSP S-ENC: " & oct2str(bspSEnc));
    ext_logDebug("BSP S-MAC: " & oct2str(bspSMac));
    ext_logDebug("Initial MCV: " & oct2str(initialMCV));

    return true;
}

/* Helper function to validate certificate roles */
private function f_validate_certificate_roles(RemoteProfileProvisioningResponse authResponse,
                                            AuthenticateClientOk auok) runs on smdpp_ConnHdlr
return boolean {
    ext_logInfo("=== Validating certificate roles ===");

    // DPauth certificate should have authentication role OID
    var octetstring dpAuthCert := enc_Certificate(authResponse.initiateAuthenticationResponse.initiateAuthenticationOk.serverCertificate);
    if (not ext_CertificateUtil_hasRSPRole(dpAuthCert, c_oid_rspRole_dp_auth)) {
        ext_logError("DPauth certificate missing authentication role OID");
        return false;
    }

    // DPpb certificate should have profile binding role OID
    var octetstring dpPbCert := enc_Certificate(auok.smdpCertificate);
    if (not ext_CertificateUtil_hasRSPRole(dpPbCert, c_oid_rspRole_dp_pb)) {
        ext_logError("DPpb certificate missing profile binding role OID");
        return false;
    }

    return true;
}

/* Helper function to validate EIN permissions */
private function f_validate_ein_permissions(charstring eid, octetstring eumCert) runs on smdpp_ConnHdlr
return boolean {
    ext_logInfo("=== Validating EUM certificate permissions ===");

    // Get permitted EINs from EUM certificate
    var charstring permittedEINs := ext_CertificateUtil_getPermittedEINs(eumCert);
    if (permittedEINs == "") {
        ext_logError("No permitted EINs found in EUM certificate");
        return false;
    }
    ext_logInfo("EUM permitted EINs: " & permittedEINs);

    // Verify our EID starts with one of the permitted EINs
    var boolean ein_match := false;
    var charstring eid_upper := to_upper(eid);

    // Split comma-separated EINs
    var integer ein_start := 0;
    for (var integer i := 0; i <= lengthof(permittedEINs); i := i + 1) {
        if (i == lengthof(permittedEINs) or permittedEINs[i] == ",") {
            var charstring ein := substr(permittedEINs, ein_start, i - ein_start);
            if (substr(eid_upper, 0, lengthof(ein)) == to_upper(ein)) {
                ein_match := true;
                ext_logInfo("EID matches permitted EIN: " & ein);
                break;
            }
            ein_start := i + 1;
        }
    }

    if (not ein_match) {
        ext_logError("EID does not match any permitted EIN");
        return false;
    }

    return true;
}

/* Helper function to check PKID validation */
private function f_validate_pkid_match(RemoteProfileProvisioningRequest authRequest,
                                     RemoteProfileProvisioningResponse authResponse)
runs on smdpp_ConnHdlr return boolean {
    var boolean pkid_found := false;
    var SubjectKeyIdentifier used_pkid :=
        authResponse.initiateAuthenticationResponse.initiateAuthenticationOk.euiccCiPKIdToBeUsed;

    for (var integer i := 0; i < lengthof(authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning); i := i + 1) {
        if (used_pkid == authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning[i]) {
            pkid_found := true;
            break;
        }
    }

    if (not pkid_found) {
        ext_logError("euiccCiPKIdToBeUsed not in requested list");
        return false;
    }

    return true;
}


private function f_TC_rsp_complete_flow(charstring id) runs on smdpp_ConnHdlr {
	f_http_init();
	f_http_register(0);
	f_http_register(1);

	ext_logInfo("Starting complete RSP flow test");

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	/* Step 1: InitiateAuthentication */
	ext_logInfo("=== Step 1: InitiateAuthentication ===");

	var RemoteProfileProvisioningRequest authRequest := f_create_initiate_authentication_request();
	var RemoteProfileProvisioningResponse authResponse :=
		f_perform_es9p_request_response(authRequest, "/gsma/rsp2/es9plus/initiateAuthentication");

	if (not isvalue(authResponse)) {
		setverdict(fail, "InitiateAuthentication request failed");
		f_rsp_client_cleanup();
		return;
	}

	if (not f_validate_initiate_authentication_response(authResponse)) {
		setverdict(fail, "InitiateAuthentication validation failed");
		f_rsp_client_cleanup();
		return;
	}


	var boolean pkid_found := false;
	for (var integer i := 0; i < lengthof(authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning); i := i + 1) {
		if ( authResponse.initiateAuthenticationResponse.initiateAuthenticationOk.euiccCiPKIdToBeUsed == authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning[i]) {
			pkid_found := true;
		}
	}
	if (not pkid_found) {
		setverdict(fail, "euiccCiPKIdToBeUsed not in requested list");
		return;
	}


	ext_logInfo("=== Step 2x: Authreq ===");

	var EUICCInfo2 euic2 := valueof(ts_EUICCInfo2);
	euic2.euiccCiPKIdListForVerification := {
		ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
		ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
	};
	euic2.euiccCiPKIdListForSigning := {
		ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
		ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
	};

	var  CtxParams1 ctxpar := valueof(ts_ctxParams1);
	ctxpar.ctxParamsForCommonAuthentication.matchingId := "TS48v4_SAIP2.3_BERTLV";

	var EuiccSigned1 euiccSig := {
		transactionId := g_transactionId,
		serverAddress := g_pars_smdpp.smdp_server_url,
		serverChallenge := g_serverChallenge,
		euiccInfo2 := euic2,
		ctxParams1 := ctxpar
	}

	var octetstring enc_euicc_tosign := enc_EuiccSigned1(euiccSig);
	var octetstring euiccSignature1 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, enc_euicc_tosign);
	var AuthenticateServerResponse authresp := {
		authenticateResponseOk := {
			euiccSigned1 := euiccSig,
			euiccSignature1 := euiccSignature1,
			euiccCertificate := dec_Certificate(ext_RSPClient_getEUICCCertificate(g_rsp_client_handle)),
			eumCertificate := dec_Certificate(ext_RSPClient_getEUMCertificate(g_rsp_client_handle))
		}
	}

	var RemoteProfileProvisioningRequest rrq := 	valueof(ts_authenticateClientRequest(transactionId := g_transactionId, authenticateServerResponse := authresp));
	var RemoteProfileProvisioningResponse rresp := valueof(f_es9p_client_transceive(rrq, tr_authenticateClientResponseEs9));
	var AuthenticateClientOk auok := rresp.authenticateClientResponseEs9.authenticateClientOk;

	if (auok.transactionId != g_transactionId or auok.smdpSigned2.transactionId != g_transactionId) {
		ext_logError("Transaction ID mismatch");
		setverdict(fail, "InitiateAuthentication validation failed");
		f_rsp_client_cleanup();
		return ;
	}

	var octetstring auresp_sigdata := enc_SmdpSigned2(auok.smdpSigned2) & '5f3740'O & euiccSignature1;
	if (not ext_RSPClient_verifyServerSignature( g_rsp_client_handle, auresp_sigdata, auok.smdpSignature2, enc_Certificate(auok.smdpCertificate))) {
		ext_logError("Server signature validation failed");
		setverdict(fail, "InitiateAuthentication validation failed");
		f_rsp_client_cleanup();
		return;
	}

    var charstring eid := ext_CertificateUtil_getEID(ext_RSPClient_getEUICCCertificate(g_rsp_client_handle));
    var octetstring eumCert := ext_RSPClient_getEUMCertificate(g_rsp_client_handle);

    if (not ext_CertificateUtil_validateEIDRange(eid, eumCert)) {
        setverdict(fail, "EID is not within permitted range of EUM certificate");
        f_rsp_client_cleanup();
        return;
    }


	/* Step 2: GetBoundProfilePackage */
	ext_logInfo("=== Step 2: GetBoundProfilePackage ===");

	var RemoteProfileProvisioningRequest packageRequest := f_create_get_bound_profile_package_request(auok.smdpSignature2);
	var RemoteProfileProvisioningResponse packageResponse := valueof(f_es9p_client_transceive(valueof(packageRequest), tr_getBoundProfilePackageResponse));
    var GetBoundProfilePackageOk packageOk := packageResponse.getBoundProfilePackageResponse.getBoundProfilePackageOk;
    var BoundProfilePackage bpp := packageOk.boundProfilePackage;
	var InitialiseSecureChannelRequest iscReq := bpp.initialiseSecureChannelRequest;

	if (not f_validate_get_bound_profile_package_response(packageResponse)) {
		setverdict(fail, "GetBoundProfilePackage validation failed");
		f_rsp_client_cleanup();
		return;
	}

	/* Comprehensive BoundProfilePackage validation */
	ext_logInfo("=== Validating BoundProfilePackage structure ===");

	// 1. Validate InitialiseSecureChannelRequest
	if (not f_validate_initialise_secure_channel_request(iscReq)) {
		f_fail_and_cleanup("InitialiseSecureChannelRequest validation failed");
		return;
	}

	// 1.1 Validate ECDH compatibility and signature
	if (not f_validate_ecdh_and_signature(iscReq, auok, packageRequest)) {
		f_fail_and_cleanup("ECDH compatibility and signature validation failed");
		return;
	}

	// 2. Validate profile elements structure
	if (not f_validate_bound_profile_package_structure(bpp)) {
		f_fail_and_cleanup("BoundProfilePackage structure validation failed");
		return;
	}

	// 3. Certificate role validation
	var octetstring dpAuthCert := enc_Certificate(authResponse.initiateAuthenticationResponse.initiateAuthenticationOk.serverCertificate);
	var octetstring dpPbCert := enc_Certificate(auok.smdpCertificate);
	if (not f_validate_certificate_roles(authResponse, auok)) {
		f_fail_and_cleanup("Certificate role validation failed");
		return;
	}

	// 4. EUM certificate validation
	if (not f_validate_ein_permissions(eid, eumCert)) {
		f_fail_and_cleanup("EIN permission validation failed");
		return;
	}

	// 5. Verify all certificates chain to the same CI
	ext_logInfo("=== Validating certificate chains ===");

	// All certificates should chain to the same root CI
	var octetstring ciCertificate := ext_RSPClient_getCICertificate(g_rsp_client_handle);

	// Verify eUICC cert chains to CI via EUM intermediate
	var octetstring euiccCertDer := ext_RSPClient_getEUICCCertificate(g_rsp_client_handle);
	if (not ext_CertificateUtil_verifyCertificateChainWithIntermediate(euiccCertDer,
																	   eumCert,
																	   ciCertificate)) {
		setverdict(fail, "eUICC certificate chain validation failed");
		f_rsp_client_cleanup();
		return;
	}

	// Verify DPpb cert chains to CI
	if (not ext_CertificateUtil_verifyCertificateChainDynamic(dpPbCert,
															g_pars_smdpp.cert_path,
															ciCertificate /* was ciPkid */)) {
		setverdict(fail, "DPpb certificate chain validation failed");
		f_rsp_client_cleanup();
		return;
	}


	// 6. ECDH and session key validation
	ext_logInfo("=== Validating ECDH key agreement and session keys ===");

	// Verify both certificates use same curve
	var charstring euiccCurve := ext_CertificateUtil_getCurveOID(euiccCertDer);
	var charstring smdpCurve := ext_CertificateUtil_getCurveOID(dpPbCert);

	if (euiccCurve != smdpCurve) {
		setverdict(fail, "eUICC and SM-DP+ certificates use different curves");
		f_rsp_client_cleanup();
		return;
	}
	ext_logInfo("Both certificates use curve: " & euiccCurve);

	// Compute shared secret
	var octetstring sharedSecret := ext_RSPClient_computeSharedSecret(g_rsp_client_handle,
																	iscReq.smdpOtpk);
	if (lengthof(sharedSecret) == 0) {
		setverdict(fail, "Failed to compute ECDH shared secret");
		f_rsp_client_cleanup();
		return;
	}

	// 7. Validate encrypted profile segments
	ext_logInfo("=== Validating encrypted profile segments ===");

	// Derive both GlobalPlatform SCP03 and BSP session keys
	var octetstring sEnc, sMac, sDek;
	if (not f_validate_and_derive_session_keys(sharedSecret, iscReq.controlRefTemplate.hostId, sEnc, sMac, sDek)) {
		f_fail_and_cleanup("Session key derivation failed");
		return;
	}

	// Also derive BSP session keys for profile validation
	var octetstring bspSEnc, bspSMac, initialMCV;
	if (not f_validate_and_derive_bsp_session_keys(sharedSecret, iscReq.controlRefTemplate.hostId, char2oct(eid), bspSEnc, bspSMac, initialMCV)) {
		f_fail_and_cleanup("BSP session key derivation failed");
		return;
	}

	// Use BSP keys for profile segment validation (matching Python server)
	if (not f_validate_profile_segments(bpp, bspSEnc, bspSMac)) {
		setverdict(fail, "Encrypted profile segment validation failed");
		f_rsp_client_cleanup();
		return;
	}

	// 8. Verify complete certificate path for all certificates
	ext_logInfo("=== Final certificate path validation ===");

	// Verify complete paths including intermediate certificates
	var boolean all_certs_valid := true;

	// Check eUICC -> EUM -> CI chain (using the EUM intermediate certificate)
	all_certs_valid := all_certs_valid and
		ext_CertificateUtil_verifyCertificateChainWithIntermediate(euiccCertDer, eumCert, ciCertificate);

	// Check DPauth -> CI chain
	all_certs_valid := all_certs_valid and
		ext_CertificateUtil_verifyCertificateChainDynamic(dpAuthCert, g_pars_smdpp.cert_path, ciCertificate /* was ciPkid */);

	// Check DPpb -> CI chain
	all_certs_valid := all_certs_valid and
		ext_CertificateUtil_verifyCertificateChainDynamic(dpPbCert, g_pars_smdpp.cert_path, ciCertificate /* was ciPkid */);

	if (not all_certs_valid) {
		setverdict(fail, "Complete certificate chain validation failed");
		f_rsp_client_cleanup();
		return;
	}

	ext_logInfo("All BoundProfilePackage validations passed successfully");


	ext_logInfo("Complete RSP flow successful");
	f_rsp_client_cleanup();
	setverdict(pass);
}

/* ============================================================================
 * TEST CASES
 * ============================================================================ */

testcase TC_rsp_complete_flow() runs on MTC_CT {
	var charstring id := testcasename();
	var smdpp_ConnHdlrPars pars := f_init_pars();
	var smdpp_ConnHdlr vc_conn;

	f_init(id);
	vc_conn := f_start_handler(refers(f_TC_rsp_complete_flow), pars);
	vc_conn.done;
	setverdict(pass);
}

control {
	execute(TC_rsp_complete_flow());
}

}