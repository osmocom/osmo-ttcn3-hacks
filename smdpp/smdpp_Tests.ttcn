/* Test Cases for GetBoundProfilePackage Operation */

// TC_SM-DP+_ES9+.GetBoundProfilePackageNIST_01_Nominal
private function f_TC_GetBoundProfilePackage_01_Nominal(charstring id) runs on smdpp_ConnHdlr {
	ext_logInfo("=== Test Case: GetBoundProfilePackage - Nominal ===");

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	/* Step 1: InitiateAuthentication */
	var InitiateAuthenticationOkEs9 authOk := f_initiate_authentication_and_validate();

	/* Step 2: AuthenticateClient */
	ext_logInfo("Step 2: AuthenticateClient");
	var AuthenticateClientOk authClientOk := f_perform_authenticate_client_standard();

	/* Step 3: GetBoundProfilePackage */
	ext_logInfo("Step 3: GetBoundProfilePackage");

	var RemoteProfileProvisioningRequest packageReq := f_create_get_bound_profile_package_request(authClientOk.smdpSignature2);
	var RemoteProfileProvisioningResponse packageResp := f_es9p_transceive_success(packageReq);

	/* Validate response structure */
	var GetBoundProfilePackageOk packageOk := packageResp.getBoundProfilePackageResponse.getBoundProfilePackageOk;

	/* Verify transaction ID */
	if (packageOk.transactionId != g_transactionId) {
		setverdict(fail, "Transaction ID mismatch in GetBoundProfilePackage response");
		f_shutdown(__FILE__, __LINE__);
	}

	/* Verify we got a BoundProfilePackage */
	var BoundProfilePackage bpp := packageOk.boundProfilePackage;

	/* Basic validation - check key structures exist */
	if (not ispresent(bpp.initialiseSecureChannelRequest)) {
		setverdict(fail, "Missing initialiseSecureChannelRequest in BoundProfilePackage");
		f_shutdown(__FILE__, __LINE__);
	}

	if (not ispresent(bpp.firstSequenceOf87) or lengthof(bpp.firstSequenceOf87) == 0) {
		setverdict(fail, "Missing or empty firstSequenceOf87 in BoundProfilePackage");
		f_shutdown(__FILE__, __LINE__);
	}

	ext_logInfo("Test passed - GetBoundProfilePackage nominal flow successful");
	ext_logInfo("BoundProfilePackage contains " & int2str(lengthof(bpp.firstSequenceOf87)) & " segments");

	f_rsp_client_cleanup();
	setverdict(pass);
}

/* Test: GetBoundProfilePackage retry with same otPK.eUICC.ECKA
 * This tests that the SM-DP+ accepts a retry with the same challenge from the eUICC
 * Reference: SGP.23 Section 4.3.13.2.4 Test Sequence #01
 */
private function f_TC_GetBoundProfilePackage_02_Retry_Same_Challenge(charstring id) runs on smdpp_ConnHdlr {
	ext_logInfo("Starting GetBoundProfilePackage retry with same challenge test");

	var octetstring saved_euicc_otpk;  /* Save the eUICC otPK for retry */

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	/* Variable to store the first otPK for comparison */
	var octetstring first_otPK;
	var octetstring g_smdpSignature2;

	/* First, perform a complete flow that will be "cancelled" */
	ext_logInfo("=== Performing initial flow (will be cancelled) ===");

	/* Step 1: InitiateAuthentication */
	var InitiateAuthenticationOkEs9 authOk := f_initiate_authentication_and_validate();

	/* Step 2: AuthenticateClient */
	var EUICCInfo2 euiccInfo2 := valueof(ts_EUICCInfo2);
	f_set_euicc_pkids(euiccInfo2);

	var CtxParams1 ctxParams := valueof(ts_ctxParams1);
	ctxParams.ctxParamsForCommonAuthentication.matchingId := "TS48v4_SAIP2.3_BERTLV";

	var EuiccSigned1 euiccSigned1 := f_create_euicc_signed1(euiccInfo2, ctxParams);

	var octetstring euiccSigned1_raw := enc_EuiccSigned1(euiccSigned1);
	var octetstring euiccSignature1 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, euiccSigned1_raw);

	var Certificate g_euicc_cert := dec_Certificate(ext_RSPClient_getEUICCCertificate(g_rsp_client_handle));
	var Certificate g_eum_cert := dec_Certificate(ext_RSPClient_getEUMCertificate(g_rsp_client_handle));

	var RemoteProfileProvisioningRequest authReq := {
		authenticateClientRequest := {
			transactionId := g_transactionId,
			authenticateServerResponse := {
				authenticateResponseOk := {
					euiccSigned1 := euiccSigned1,
					euiccSignature1 := euiccSignature1,
					euiccCertificate := g_euicc_cert,
					eumCertificate := g_eum_cert
				}
			}
		}
	};

	var RemoteProfileProvisioningResponse authResp := f_es9p_transceive_success(authReq);
	var AuthenticateClientOk authClientOk := authResp.authenticateClientResponseEs9.authenticateClientOk;

	/* Store smdpSignature2 for later use */
	g_smdpSignature2 := authClientOk.smdpSignature2;

	/* Step 3: First GetBoundProfilePackage - will be cancelled */
	ext_logInfo("First GetBoundProfilePackage (to be cancelled)");

	/* Generate and save the eUICC otPK for reuse */
	saved_euicc_otpk := ext_RSPClient_generateEUICCOtpk(g_rsp_client_handle);

	/* Create PrepareDownloadRequest manually to use saved otPK */
	var PrepareDownloadResponse prepDownloadResp := f_create_prepare_download_response_with_otpk(
		authClientOk.smdpSignature2, saved_euicc_otpk);

	var RemoteProfileProvisioningRequest packageReq := {
		getBoundProfilePackageRequest := {
			transactionId := g_transactionId,
			prepareDownloadResponse := prepDownloadResp
		}
	};

	var RemoteProfileProvisioningResponse packageResp := f_es9p_transceive_success(packageReq);

	/* Extract and store the otPK from the first response */
	var GetBoundProfilePackageOk packageOk := packageResp.getBoundProfilePackageResponse.getBoundProfilePackageOk;
	var BoundProfilePackage bpp := packageOk.boundProfilePackage;
	var InitialiseSecureChannelRequest iscReq := bpp.initialiseSecureChannelRequest;
	first_otPK := iscReq.smdpOtpk;

	ext_logInfo("First otPK.SM-DP+.ECKA: " & oct2str(first_otPK));

	/* Simulate session cancellation - in real test this would be done via CancelSession */
	ext_logInfo("=== Simulating session cancellation ===");

	/* Now perform the retry with the same otPK.eUICC.ECKA */
	ext_logInfo("=== Performing retry with same otPK.eUICC.ECKA ===");

	/* Step 4: InitiateAuthentication for retry */
	authOk := f_initiate_authentication_and_validate();

	/* Step 5: AuthenticateClient for retry with same values */
	euiccSigned1 := {
		transactionId := g_transactionId,
		serverAddress := g_pars_smdpp.smdp_server_url,
		serverChallenge := g_serverChallenge,
		euiccInfo2 := euiccInfo2,
		ctxParams1 := ctxParams
	};

	euiccSigned1_raw := enc_EuiccSigned1(euiccSigned1);
	euiccSignature1 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, euiccSigned1_raw);

	authReq := {
		authenticateClientRequest := {
			transactionId := g_transactionId,
			authenticateServerResponse := {
				authenticateResponseOk := {
					euiccSigned1 := euiccSigned1,
					euiccSignature1 := euiccSignature1,
					euiccCertificate := g_euicc_cert,
					eumCertificate := g_eum_cert
				}
			}
		}
	};

	authResp := f_es9p_transceive_success(authReq);
	authClientOk := authResp.authenticateClientResponseEs9.authenticateClientOk;

	/* Step 6: Retry GetBoundProfilePackage with the SAME otPK.eUICC.ECKA */
	ext_logInfo("Retry GetBoundProfilePackage with same otPK.eUICC.ECKA");

	/* Important: Reuse the saved eUICC otPK from the first attempt */
	prepDownloadResp := f_create_prepare_download_response_with_otpk(
		authClientOk.smdpSignature2, saved_euicc_otpk);

	packageReq := {
		getBoundProfilePackageRequest := {
			transactionId := g_transactionId,
			prepareDownloadResponse := prepDownloadResp
		}
	};

	packageResp := f_es9p_transceive_success(packageReq);

	/* Verify the retry was successful */
	packageOk := packageResp.getBoundProfilePackageResponse.getBoundProfilePackageOk;
	bpp := packageOk.boundProfilePackage;
	iscReq := bpp.initialiseSecureChannelRequest;

	/* According to test spec, the otPK.SM-DP+.ECKA should match the first one */
	var octetstring retry_otPK := iscReq.smdpOtpk;
	ext_logInfo("Retry otPK.SM-DP+.ECKA: " & oct2str(retry_otPK));

	if (retry_otPK == first_otPK) {
		ext_logInfo("PASS: otPK.SM-DP+.ECKA matches - retry with same challenge accepted");
		setverdict(pass);
	} else {
		setverdict(fail, "otPK.SM-DP+.ECKA does not match - expected same value on retry");
	}

	f_rsp_client_cleanup();
}

/* Test: GetBoundProfilePackage retry with different otPK.eUICC.ECKA
 * This tests the SM-DP+ behavior when eUICC provides a different challenge
 * Reference: SGP.23 Section 4.3.13.2.7 Test Sequence #01
 */
private function f_TC_GetBoundProfilePackage_03_Retry_Different_Challenge(charstring id) runs on smdpp_ConnHdlr {
	ext_logInfo("Starting GetBoundProfilePackage retry with different challenge test");

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	/* Variable to store the first otPK for comparison */
	var octetstring first_otPK;

	/* First, perform a complete flow that will be "cancelled" */
	ext_logInfo("=== Performing initial flow (will be cancelled) ===");

	/* Steps 1-3: Complete initial flow similar to test #02 */
	var InitiateAuthenticationOkEs9 authOk := f_initiate_authentication_and_validate();

	/* AuthenticateClient */
	var EUICCInfo2 euiccInfo2 := valueof(ts_EUICCInfo2);
	f_set_euicc_pkids(euiccInfo2);

	var CtxParams1 ctxParams := valueof(ts_ctxParams1);
	ctxParams.ctxParamsForCommonAuthentication.matchingId := "TS48v4_SAIP2.3_BERTLV";

	var EuiccSigned1 euiccSigned1 := f_create_euicc_signed1(euiccInfo2, ctxParams);

	var octetstring euiccSigned1_raw := enc_EuiccSigned1(euiccSigned1);
	var octetstring euiccSignature1 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, euiccSigned1_raw);

	var Certificate g_euicc_cert := dec_Certificate(ext_RSPClient_getEUICCCertificate(g_rsp_client_handle));
	var Certificate g_eum_cert := dec_Certificate(ext_RSPClient_getEUMCertificate(g_rsp_client_handle));

	var RemoteProfileProvisioningRequest authReq := {
		authenticateClientRequest := {
			transactionId := g_transactionId,
			authenticateServerResponse := {
				authenticateResponseOk := {
					euiccSigned1 := euiccSigned1,
					euiccSignature1 := euiccSignature1,
					euiccCertificate := g_euicc_cert,
					eumCertificate := g_eum_cert
				}
			}
		}
	};

	var RemoteProfileProvisioningResponse authResp := f_es9p_transceive_success(authReq);
	var AuthenticateClientOk authClientOk := authResp.authenticateClientResponseEs9.authenticateClientOk;

	/* First GetBoundProfilePackage */
	var RemoteProfileProvisioningRequest packageReq := f_create_get_bound_profile_package_request(authClientOk.smdpSignature2);
	var RemoteProfileProvisioningResponse packageResp := f_es9p_transceive_success(packageReq);

	/* Extract and store the otPK from first response */
	var GetBoundProfilePackageOk packageOk := packageResp.getBoundProfilePackageResponse.getBoundProfilePackageOk;
	var BoundProfilePackage bpp := packageOk.boundProfilePackage;
	var InitialiseSecureChannelRequest iscReq := bpp.initialiseSecureChannelRequest;
	first_otPK := iscReq.smdpOtpk;

	ext_logInfo("First otPK.SM-DP+.ECKA: " & oct2str(first_otPK));

	/* Simulate session cancellation */
	ext_logInfo("=== Simulating session cancellation ===");

	/* Now perform retry with DIFFERENT otPK.eUICC.ECKA */
	ext_logInfo("=== Performing retry with DIFFERENT otPK.eUICC.ECKA ===");

	/* New InitiateAuthentication for retry */
	authOk := f_initiate_authentication_and_validate();

	/* New AuthenticateClient */
	euiccSigned1 := {
		transactionId := g_transactionId,
		serverAddress := g_pars_smdpp.smdp_server_url,
		serverChallenge := g_serverChallenge,
		euiccInfo2 := euiccInfo2,
		ctxParams1 := ctxParams
	};

	euiccSigned1_raw := enc_EuiccSigned1(euiccSigned1);
	euiccSignature1 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, euiccSigned1_raw);

	authReq := {
		authenticateClientRequest := {
			transactionId := g_transactionId,
			authenticateServerResponse := {
				authenticateResponseOk := {
					euiccSigned1 := euiccSigned1,
					euiccSignature1 := euiccSignature1,
					euiccCertificate := g_euicc_cert,
					eumCertificate := g_eum_cert
				}
			}
		}
	};

	authResp := f_es9p_transceive_success(authReq);
	authClientOk := authResp.authenticateClientResponseEs9.authenticateClientOk;

	/* Create GetBoundProfilePackage request with NEW otPK.eUICC.ECKA */
	/* Generate a new ECDH key pair to simulate different otPK */
	var octetstring new_euicc_otpk := ext_RSPClient_generateEUICCOtpk(g_rsp_client_handle);
	ext_logInfo("Generated new otPK.eUICC.ECKA: " & oct2str(new_euicc_otpk));

	/* Create PrepareDownloadRequest with new otPK */
	var PrepareDownloadRequest prepDownloadReq := {
		smdpSigned2 := authClientOk.smdpSigned2,
		smdpSignature2 := authClientOk.smdpSignature2,
		hashCc := omit,
		smdpCertificate := authClientOk.smdpCertificate
	};

	var EUICCSigned2 euiccSigned2 := {
		transactionId := g_transactionId,
		euiccOtpk := new_euicc_otpk,  /* NEW otPK */
		hashCc := omit
	};

	var octetstring euiccSigned2_raw := enc_EUICCSigned2(euiccSigned2);
	/* Concatenate euiccSigned2 with smdpSignature2 directly (no TLV wrapper) */
	var octetstring euiccSignature2 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle,
		euiccSigned2_raw & authClientOk.smdpSignature2);

	var PrepareDownloadResponse prepDownloadResp := {
		downloadResponseOk := {
			euiccSigned2 := euiccSigned2,
			euiccSignature2 := euiccSignature2
		}
	};

	packageReq := {
		getBoundProfilePackageRequest := {
			transactionId := g_transactionId,
			prepareDownloadResponse := prepDownloadResp
		}
	};

	/* According to spec, server may return error or accept with different otPK */
	packageResp := f_es9p_transceive_success(packageReq);

	/* Verify response */
	packageOk := packageResp.getBoundProfilePackageResponse.getBoundProfilePackageOk;
	bpp := packageOk.boundProfilePackage;
	iscReq := bpp.initialiseSecureChannelRequest;

	var octetstring retry_otPK := iscReq.smdpOtpk;
	ext_logInfo("Retry otPK.SM-DP+.ECKA: " & oct2str(retry_otPK));

	if (retry_otPK != first_otPK) {
		ext_logInfo("PASS: otPK.SM-DP+.ECKA is different - new session established");
		setverdict(pass);
	} else {
		setverdict(fail, "otPK.SM-DP+.ECKA is the same - expected different value for new session");
	}

	f_rsp_client_cleanup();
}

/* Test: GetBoundProfilePackage with preparation error
 * This tests error handling when PrepareDownloadResponse contains an error
 * Reference: SGP.23 GetBoundProfilePackage error cases
 */
private function f_TC_GetBoundProfilePackage_04_Preparation_Error(charstring id) runs on smdpp_ConnHdlr {
	ext_logInfo("Starting GetBoundProfilePackage preparation error test");

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	/* Perform InitiateAuthentication and AuthenticateClient */
	var InitiateAuthenticationOkEs9 authOk := f_initiate_authentication_and_validate();

	/* AuthenticateClient */
	var EUICCInfo2 euiccInfo2 := valueof(ts_EUICCInfo2);
	f_set_euicc_pkids(euiccInfo2);

	var CtxParams1 ctxParams := valueof(ts_ctxParams1);
	ctxParams.ctxParamsForCommonAuthentication.matchingId := "TS48v4_SAIP2.3_BERTLV";

	var EuiccSigned1 euiccSigned1 := f_create_euicc_signed1(euiccInfo2, ctxParams);

	var octetstring euiccSigned1_raw := enc_EuiccSigned1(euiccSigned1);
	var octetstring euiccSignature1 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, euiccSigned1_raw);

	var Certificate g_euicc_cert := dec_Certificate(ext_RSPClient_getEUICCCertificate(g_rsp_client_handle));
	var Certificate g_eum_cert := dec_Certificate(ext_RSPClient_getEUMCertificate(g_rsp_client_handle));

	var RemoteProfileProvisioningRequest authReq := {
		authenticateClientRequest := {
			transactionId := g_transactionId,
			authenticateServerResponse := {
				authenticateResponseOk := {
					euiccSigned1 := euiccSigned1,
					euiccSignature1 := euiccSignature1,
					euiccCertificate := g_euicc_cert,
					eumCertificate := g_eum_cert
				}
			}
		}
	};

	var RemoteProfileProvisioningResponse authResp := f_es9p_transceive_success(authReq);
	var AuthenticateClientOk authClientOk := authResp.authenticateClientResponseEs9.authenticateClientOk;

	/* Create GetBoundProfilePackage request with error PrepareDownloadResponse */
	ext_logInfo("Sending GetBoundProfilePackage with downloadResponseError");

	/* Create PrepareDownloadResponse with error */
	var PrepareDownloadResponse prepDownloadResp := {
		downloadResponseError := {
			transactionId := g_transactionId,
			downloadErrorCode := 127  /* undefinedError */
		}
	};

	var RemoteProfileProvisioningRequest packageReq := {
		getBoundProfilePackageRequest := {
			transactionId := g_transactionId,
			prepareDownloadResponse := prepDownloadResp
		}
	};

	/* Expect an error response */
	var DecodedRPPReponse_Wrap response := f_es9p_transceive_wrap(packageReq);

	if (ispresent(response.err)) {
		var JSON_ESx_FunctionExecutionStatusCodeData errorData := response.err;
		ext_logInfo("Received expected error response");
		ext_logInfo("Subject Code: " & errorData.subjectCode);
		ext_logInfo("Reason Code: " & errorData.reasonCode);

		/* The server should return an appropriate error when PrepareDownloadResponse contains an error */
		setverdict(pass, "Server correctly handled PrepareDownloadResponse error");
	} else if (ispresent(response.asn1_pdu)) {
		setverdict(fail, "Expected error response but got success response");
	} else {
		setverdict(fail, "Unexpected response type");
	}

	f_rsp_client_cleanup();
}

