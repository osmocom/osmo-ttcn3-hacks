    octetstring sharedSecret,
    integer keyType,
    integer keyLength,
    octetstring hostId,
    charstring eid,
    octetstring firstSequenceOf87,
    octetstring sequenceOf88,
    octetstring secondSequenceOf87,
    octetstring sequenceOf86
) return ProcessedBoundProfilePackage;

/* HTTP Client Functions */
