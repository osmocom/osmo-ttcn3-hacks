// InitialiseSecureChannelRequest


private function f_TC_rsp_complete_flow(charstring id) runs on smdpp_ConnHdlr {
	f_http_init();
	f_http_register(0);
	f_http_register(1);

	ext_logInfo("Starting complete RSP flow test");

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	/* Step 1: InitiateAuthentication */
	ext_logInfo("=== Step 1: InitiateAuthentication ===");

	var RemoteProfileProvisioningRequest authRequest := f_create_initiate_authentication_request();
	var RemoteProfileProvisioningResponse authResponse :=
		f_perform_es9p_request_response(authRequest, "/gsma/rsp2/es9plus/initiateAuthentication");

	if (not isvalue(authResponse)) {
		setverdict(fail, "InitiateAuthentication request failed");
		f_rsp_client_cleanup();
		return;
	}

	if (not f_validate_initiate_authentication_response(authResponse)) {
		setverdict(fail, "InitiateAuthentication validation failed");
		f_rsp_client_cleanup();
		return;
	}


	var boolean pkid_found := false;
	for (var integer i := 0; i < lengthof(authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning); i := i + 1) {
		if ( authResponse.initiateAuthenticationResponse.initiateAuthenticationOk.euiccCiPKIdToBeUsed == authRequest.initiateAuthenticationRequest.euiccInfo1.euiccCiPKIdListForSigning[i]) {
			pkid_found := true;
		}
	}
	if (not pkid_found) {
		setverdict(fail, "euiccCiPKIdToBeUsed not in requested list");
		return;
	}


	ext_logInfo("=== Step 2x: Authreq ===");

	var EUICCInfo2 euic2 := {
		profileVersion := '414243'O,
		svn := '02000C'O,
		euiccFirmwareVer := '414243'O,
		extCardResource := '414243'O,
		uiccCapability := '1111111111111111111'B,
		ts102241Version := omit,
		globalplatformVersion := omit,
		rspCapability := '1111'B,
		euiccCiPKIdListForVerification := {
			ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
			ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
		},
		euiccCiPKIdListForSigning := {
			ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
			ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
		},
		euiccCategory := omit,
		forbiddenProfilePolicyRules := omit,
		ppVersion := '414243'O,
		sasAcreditationNumber := "123456",
		certificationDataObject := omit,
		treProperties := omit,
		treProductReference := omit,
		additionalEuiccProfilePackageVersions := omit
	}

	var  CtxParams1 ctxpar := {
	ctxParamsForCommonAuthentication := {
		matchingId := "TS48v4_SAIP2.3_BERTLV",
		deviceInfo := {
			tac := '12345678'O,
			deviceCapabilities := {
				gsmSupportedRelease := omit,
				utranSupportedRelease := omit,
				cdma2000onexSupportedRelease := omit,
				cdma2000hrpdSupportedRelease := omit,
				cdma2000ehrpdSupportedRelease := omit,
				eutranEpcSupportedRelease := omit,
				contactlessSupportedRelease := omit,
				rspCrlSupportedVersion := omit,
				nrEpcSupportedRelease := omit,
				nr5gcSupportedRelease := omit,
				eutran5gcSupportedRelease := omit,
				lpaSvn := omit,
				catSupportedClasses := omit,
				euiccFormFactorType := omit,
				deviceAdditionalFeatureSupport := omit
			},
			imei := omit
		}
	}
}


var EuiccSigned1 euiccSig := {
	 transactionId := g_transactionId,
	 serverAddress := g_pars_smdpp.smdp_server_url,
	 serverChallenge := g_serverChallenge,
	 euiccInfo2 := euic2,
	 ctxParams1 := ctxpar
}

	var octetstring enc_euicc_tosign := enc_EuiccSigned1(euiccSig);
	var octetstring euiccSignature1 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, enc_euicc_tosign);



var AuthenticateServerResponse
authresp := {
	authenticateResponseOk := {
		euiccSigned1 := euiccSig,
		euiccSignature1 := euiccSignature1,
		euiccCertificate := dec_Certificate(ext_RSPClient_getEUICCCertificate(g_rsp_client_handle)),
//		euiccCertificate := ts_cert_euicc_brp,
		eumCertificate := dec_Certificate(ext_RSPClient_getEUMCertificate(g_rsp_client_handle))
//		eumCertificate := ts_cert_eum_brp

	}
}




	var RemoteProfileProvisioningRequest rrq := 	valueof(ts_authenticateClientRequest(transactionId := g_transactionId, authenticateServerResponse := authresp));
	// var RemoteProfileProvisioningResponse authrqresp := f_perform_es9p_request_response(rrq, "/gsma/rsp2/es9plus/authenticateClient");
	var RemoteProfileProvisioningResponse rresp := valueof(f_es9p_client_transceive(rrq, tr_authenticateClientResponseEs9));
	var AuthenticateClientOk auok := rresp.authenticateClientResponseEs9.authenticateClientOk;

	if (auok.transactionId != g_transactionId or auok.smdpSigned2.transactionId != g_transactionId) {
		ext_logError("Transaction ID mismatch");
		setverdict(fail, "InitiateAuthentication validation failed");
		f_rsp_client_cleanup();
		return ;
	}

	var octetstring auresp_sigdata := enc_SmdpSigned2(auok.smdpSigned2) & '5f3740'O & euiccSignature1;
	if (not ext_RSPClient_verifyServerSignature( g_rsp_client_handle, auresp_sigdata, auok.smdpSignature2, enc_Certificate(auok.smdpCertificate))) {
		ext_logError("Server signature validation failed");
		setverdict(fail, "InitiateAuthentication validation failed");
		f_rsp_client_cleanup();
		return;
	}

    var charstring eid := ext_CertificateUtil_getEID(ext_RSPClient_getEUICCCertificate(g_rsp_client_handle));
    var octetstring eumCert := ext_RSPClient_getEUMCertificate(g_rsp_client_handle);

    if (not ext_CertificateUtil_validateEIDRange(eid, eumCert)) {
        setverdict(fail, "EID is not within permitted range of EUM certificate");
        f_rsp_client_cleanup();
        return;
    }


	/* Step 2: GetBoundProfilePackage */
	ext_logInfo("=== Step 2: GetBoundProfilePackage ===");

	var RemoteProfileProvisioningRequest packageRequest := f_create_get_bound_profile_package_request(auok.smdpSignature2);
	var RemoteProfileProvisioningResponse packageResponse := valueof(f_es9p_client_transceive(valueof(packageRequest), tr_getBoundProfilePackageResponse));


    var GetBoundProfilePackageOk packageOk := packageResponse.getBoundProfilePackageResponse.getBoundProfilePackageOk;
    var BoundProfilePackage bpp := packageOk.boundProfilePackage;
	var InitialiseSecureChannelRequest iscReq := bpp.initialiseSecureChannelRequest;

	if (not f_validate_get_bound_profile_package_response(packageResponse)) {
		setverdict(fail, "GetBoundProfilePackage validation failed");
		f_rsp_client_cleanup();
		return;
	}

	/* Comprehensive BoundProfilePackage validation */
	ext_logInfo("=== Validating BoundProfilePackage structure ===");

	// 1. Validate InitialiseSecureChannelRequest

	// 1b. RemoteOpId must be installBoundProfilePackage (1)
	if (iscReq.remoteOpId != 1) {
		setverdict(fail, "Invalid remoteOpId, expected installBoundProfilePackage(1)");
		f_rsp_client_cleanup();
		return;
	}

	// 1c. Validate ControlRefTemplate
	if (iscReq.controlRefTemplate.keyType != '88'O) { // AES
		setverdict(fail, "Invalid key type, expected AES (0x88)");
		f_rsp_client_cleanup();
		return;
	}

	if (iscReq.controlRefTemplate.keyLen != '10'O) { // 16 bytes
		setverdict(fail, "Invalid key length, expected 16 bytes (0x10)");
		f_rsp_client_cleanup();
		return;
	}

	if (lengthof(iscReq.controlRefTemplate.hostId) < 4 or
		lengthof(iscReq.controlRefTemplate.hostId) > 16) {
		setverdict(fail, "Invalid hostId length");
		f_rsp_client_cleanup();
		return;
	}

	// 1d. Verify smdpOtpk is present and valid EC public key
	if (not ispresent(iscReq.smdpOtpk) or lengthof(iscReq.smdpOtpk) == 0) {
		setverdict(fail, "Missing or empty smdpOtpk");
		f_rsp_client_cleanup();
		return;
	}

	// Check it's an uncompressed EC point
	if (iscReq.smdpOtpk[0] != '04'O) {
		setverdict(fail, "smdpOtpk is not an uncompressed EC point");
		f_rsp_client_cleanup();
		return;
	}

	// 1e. Verify ECDH compatibility between eUICC and SM-DP+ public keys
	var octetstring euiccOtpk := ext_RSPClient_getEUICCOtpk(g_rsp_client_handle);
	if (not ext_CertificateUtil_verifyECDHCompatible(euiccOtpk, iscReq.smdpOtpk)) {
		setverdict(fail, "eUICC and SM-DP+ public keys are not ECDH compatible");
		f_rsp_client_cleanup();
		return;
	}


	// if (not auok.smdpSigned2.bppEuiccOtpk == iscReq.smdpOtpk) {
	// 	setverdict(fail, "Server ecdh mismatch!");
	// 	return;
	// }


	// 1f. Verify InitialiseSecureChannelRequest signature
	// Build the data that was signed (without the signature field)
	// var InitialiseSecureChannelRequest iscReqForSigning := iscReq;
	// iscReqForSigning.smdpSign := ''O; // Clear signature field
	// var octetstring iscReqData := enc_InitialiseSecureChannelRequest(iscReqForSigning);

	// // The signature should be verified with DPpb certificate
	// if (not ext_RSPClient_verifyInitialiseSecureChannelRequest(g_rsp_client_handle,
	// 														iscReqData,
	// 														iscReq.smdpSign,
	// 														enc_Certificate(auok.smdpCertificate))) {
	// 	setverdict(fail, "InitialiseSecureChannelRequest signature verification failed");
	// 	f_rsp_client_cleanup();
	// 	return;
	// }
	var InitialiseSecureChannelRequest_ver toencsec := {
		remoteOpId := 1,
		transactionId := g_transactionId,
		controlRefTemplate := iscReq.controlRefTemplate,
		smdpOtpk := iscReq.smdpOtpk,
		euiccOtpk := packageRequest.getBoundProfilePackageRequest.prepareDownloadResponse.downloadResponseOk.euiccSigned2.euiccOtpk
	}
	var octetstring encsecr := encode_DER_InitialiseSecureChannelRequest_ver(toencsec);
	var octetstring trunc_initsec := substr(encsecr, 4, lengthof(encsecr)-4);
	// log(trunc_initsec);

	// BF23 81AF
	// 820101
	// 8010 1C3C833FB84A4DBE8E88 CD894F1C58D5
	// A610 800188 810110 84086D61686C7A656974
	// 5F49410 4D810BFA5BCB6BF2652A862CC5D780CC48472722345F241A2416D27CDBE95F008E3B96D124B6EC5918EC36CDD744323361D7CEC9875E62FA33645E6B4E21B5188
	// 5F49410 4A1779334FA2786E51B445536B0EC4D2310D268B75891EEA452EEFCC3076BB1EC948EF4ABF14D6BEC8AA7389470D8BD439DA7C5299B90BD5F593BFC5499353603

	if (not ext_RSPClient_verifyServerSignature(g_rsp_client_handle, trunc_initsec, iscReq.smdpSign, enc_Certificate(auok.smdpCertificate))) {
		setverdict(fail, "Server 11 signature validation failed");
		f_rsp_client_cleanup();
		return;
	}



	// var ControlRefTemplate crt := {
	// 	keyType := iscReq.controlRefTemplate.keyType,
	// 	keyLen := iscReq.controlRefTemplate.keyLen,
	// 	hostId := iscReq.controlRefTemplate.hostId
	// };
	// var octetstring crtEncoded := enc_ControlRefTemplate(crt);


	// // Verify InitialiseSecureChannelRequest signature
	// if (not ext_RSPClient_verifyInitialiseSecureChannelRequest(g_rsp_client_handle,
	// 														iscReq.transactionId,
	// 														crtEncoded,
	// 														iscReq.smdpOtpk,
	// 														iscReq.smdpSign,
	// 														enc_Certificate(auok.smdpCertificate))) {
	// 	setverdict(fail, "InitialiseSecureChannelRequest signature verification failed");
	// 	f_rsp_client_cleanup();
	// 	return;
	// }

	// 2. Validate profile elements structure
	if (not ispresent(bpp.firstSequenceOf87) or lengthof(bpp.firstSequenceOf87) == 0) {
		setverdict(fail, "Missing or empty firstSequenceOf87 (ConfigureISDP)");
		f_rsp_client_cleanup();
		return;
	}

	if (not ispresent(bpp.sequenceOf88) or lengthof(bpp.sequenceOf88) == 0) {
		setverdict(fail, "Missing or empty sequenceOf88 (StoreMetadata)");
		f_rsp_client_cleanup();
		return;
	}

	if (not ispresent(bpp.sequenceOf86) or lengthof(bpp.sequenceOf86) == 0) {
		setverdict(fail, "Missing or empty sequenceOf86 (LoadProfileElements)");
		f_rsp_client_cleanup();
		return;
	}

	// 3. Certificate role validation
	ext_logInfo("=== Validating certificate roles ===");

	// DPauth certificate should have authentication role OID
	var octetstring dpAuthCert := enc_Certificate(authResponse.initiateAuthenticationResponse.initiateAuthenticationOk.serverCertificate);
	if (not ext_CertificateUtil_hasRSPRole(dpAuthCert, c_oid_rspRole_dp_auth)) {
		setverdict(fail, "DPauth certificate missing authentication role OID");
		f_rsp_client_cleanup();
		return;
	}

	// DPpb certificate should have profile binding role OID
	var octetstring dpPbCert := enc_Certificate(auok.smdpCertificate);
	if (not ext_CertificateUtil_hasRSPRole(dpPbCert, c_oid_rspRole_dp_pb)) {
		setverdict(fail, "DPpb certificate missing profile binding role OID");
		f_rsp_client_cleanup();
		return;
	}

	// 4. EUM certificate validation
	ext_logInfo("=== Validating EUM certificate permissions ===");

	// Get permitted EINs from EUM certificate
	var charstring permittedEINs := ext_CertificateUtil_getPermittedEINs(eumCert);
	if (permittedEINs == "") {
		setverdict(fail, "No permitted EINs found in EUM certificate");
		f_rsp_client_cleanup();
		return;
	}
	ext_logInfo("EUM permitted EINs: " & permittedEINs);

	// Verify our EID starts with one of the permitted EINs
	var boolean ein_match := false;
	var charstring eid_upper := to_upper(eid);

	// Split comma-separated EINs
	var integer ein_start := 0;
	for (var integer i := 0; i <= lengthof(permittedEINs); i := i + 1) {
		if (i == lengthof(permittedEINs) or permittedEINs[i] == ",") {
			var charstring ein := substr(permittedEINs, ein_start, i - ein_start);
			if (substr(eid_upper, 0, lengthof(ein)) == to_upper(ein)) {
				ein_match := true;
				ext_logInfo("EID matches permitted EIN: " & ein);
				break;
			}
			ein_start := i + 1;
		}
	}

	if (not ein_match) {
		setverdict(fail, "EID does not match any permitted EIN");
		f_rsp_client_cleanup();
		return;
	}

	// 5. Verify all certificates chain to the same CI
	ext_logInfo("=== Validating certificate chains ===");

	// All certificates should chain to the same root CI
	var octetstring ciCertificate := ext_RSPClient_getCICertificate(g_rsp_client_handle); //substr(authResponse.initiateAuthenticationResponse.initiateAuthenticationOk.euiccCiPKIdToBeUsed, 2, 20); // Skip tag

	log(ciCertificate /* was ciPkid */);

	// Verify eUICC cert chains to CI via EUM intermediate
	var octetstring euiccCertDer := ext_RSPClient_getEUICCCertificate(g_rsp_client_handle);
	if (not ext_CertificateUtil_verifyCertificateChainWithIntermediate(euiccCertDer,
																	   eumCert,
																	   ciCertificate)) {
		setverdict(fail, "eUICC certificate chain validation failed");
		f_rsp_client_cleanup();
		return;
	}

	// Verify DPpb cert chains to CI
	if (not ext_CertificateUtil_verifyCertificateChainDynamic(dpPbCert,
															g_pars_smdpp.cert_path,
															ciCertificate /* was ciPkid */)) {
		setverdict(fail, "DPpb certificate chain validation failed");
		f_rsp_client_cleanup();
		return;
	}


	// 6. ECDH and session key validation
	ext_logInfo("=== Validating ECDH key agreement and session keys ===");

	// Verify both certificates use same curve
	var charstring euiccCurve := ext_CertificateUtil_getCurveOID(euiccCertDer);
	var charstring smdpCurve := ext_CertificateUtil_getCurveOID(dpPbCert);

	if (euiccCurve != smdpCurve) {
		setverdict(fail, "eUICC and SM-DP+ certificates use different curves");
		f_rsp_client_cleanup();
		return;
	}
	ext_logInfo("Both certificates use curve: " & euiccCurve);

	// Compute shared secret
	var octetstring sharedSecret := ext_RSPClient_computeSharedSecret(g_rsp_client_handle,
																	iscReq.smdpOtpk);
	if (lengthof(sharedSecret) == 0) {
		setverdict(fail, "Failed to compute ECDH shared secret");
		f_rsp_client_cleanup();
		return;
	}

	// Derive and validate session keys
	if (not f_validate_session_keys(sharedSecret, iscReq.controlRefTemplate.hostId)) {
		setverdict(fail, "Session key derivation failed");
		f_rsp_client_cleanup();
		return;
	}

	// 7. Validate encrypted profile segments
	ext_logInfo("=== Validating encrypted profile segments ===");

	var octetstring sEnc, sMac, sDek;
	ext_Crypto_deriveSessionKeys(sharedSecret, iscReq.controlRefTemplate.hostId,
							sEnc, sMac, sDek);

	if (not f_validate_profile_segments(bpp, sEnc, sMac)) {
		setverdict(fail, "Encrypted profile segment validation failed");
		f_rsp_client_cleanup();
		return;
	}

	// 8. Verify complete certificate path for all certificates
	ext_logInfo("=== Final certificate path validation ===");

	// Verify complete paths including intermediate certificates
	var boolean all_certs_valid := true;

	// Check eUICC -> EUM -> CI chain
	all_certs_valid := all_certs_valid and
		ext_CertificateUtil_verifyCertificateChainDynamic(euiccCertDer, g_pars_smdpp.cert_path, ciCertificate /* was ciPkid */); // TODO: ciCertificate /* was ciPkid */ should be actual cert

	// Check DPauth -> CI chain
	all_certs_valid := all_certs_valid and
		ext_CertificateUtil_verifyCertificateChainDynamic(dpAuthCert, g_pars_smdpp.cert_path, ciCertificate /* was ciPkid */);

	// Check DPpb -> CI chain
	all_certs_valid := all_certs_valid and
		ext_CertificateUtil_verifyCertificateChainDynamic(dpPbCert, g_pars_smdpp.cert_path, ciCertificate /* was ciPkid */);

	if (not all_certs_valid) {
		setverdict(fail, "Complete certificate chain validation failed");
		f_rsp_client_cleanup();
		return;
	}

	ext_logInfo("All BoundProfilePackage validations passed successfully");


	ext_logInfo("Complete RSP flow successful");
	f_rsp_client_cleanup();
	setverdict(pass);
}

private function f_TC_rsp_authentication_only(charstring id) runs on smdpp_ConnHdlr {
	f_http_init();
	f_http_register(0);

	ext_logInfo("Starting authentication only test");

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	var RemoteProfileProvisioningRequest authRequest := f_create_initiate_authentication_request();
	var RemoteProfileProvisioningResponse authResponse :=
		f_perform_es9p_request_response(authRequest, "/gsma/rsp2/es9plus/initiateAuthentication");

	if (not isvalue(authResponse)) {
		setverdict(fail, "InitiateAuthentication request failed");
		f_rsp_client_cleanup();
		return;
	}

	if (f_validate_initiate_authentication_response(authResponse)) {
		ext_logInfo("Authentication successful");
		setverdict(pass);
	} else {
		setverdict(fail, "Authentication validation failed");
	}

	f_rsp_client_cleanup();
}

private function f_TC_rsp_asn1_validation(charstring id) runs on smdpp_ConnHdlr {
	ext_logInfo("Starting ASN.1 validation test");

	if (not f_rsp_client_init()) {
		setverdict(fail, "RSP client initialization failed");
		return;
	}

	/* Test ASN.1 encoding/decoding with sample data */
	var EUICCInfo1 testInfo := {
		svn := '020200'O,
		euiccCiPKIdListForVerification := {
			ext_hexToBytes("AABBCCDDEEFF"),
			ext_hexToBytes("112233445566")
		},
		euiccCiPKIdListForSigning := {
			ext_hexToBytes("AABBCCDDEEFF")
		}
	};

	/* Encode to ASN.1 */
	var octetstring encoded := enc_EUICCInfo1(testInfo);
	ext_logInfo("Encoded EUICCInfo1 length: " & int2str(lengthof(encoded)));
	ext_logDebug("Encoded hex: " & ext_bytesToHex(encoded));

	ext_logInfo("ASN.1 xxxxxx");

	/* Decode back */
	var EUICCInfo1 decoded := dec_EUICCInfo1(encoded);

	/* Verify round-trip */
	if (decoded.svn == testInfo.svn and
	    lengthof(decoded.euiccCiPKIdListForVerification) == lengthof(testInfo.euiccCiPKIdListForVerification)) {
		ext_logInfo("ASN.1 round-trip validation successful");
		setverdict(pass);
	} else {
		ext_logError("ASN.1 round-trip validation failed");
		setverdict(fail);
	}

	f_rsp_client_cleanup();
}

/* ============================================================================
 * TEST CASES
 * ============================================================================ */

testcase TC_rsp_complete_flow() runs on MTC_CT {
	var charstring id := testcasename();
	var smdpp_ConnHdlrPars pars := f_init_pars();
	var smdpp_ConnHdlr vc_conn;

	f_init(id);
	vc_conn := f_start_handler(refers(f_TC_rsp_complete_flow), pars);
	vc_conn.done;
	setverdict(pass);
}

testcase TC_rsp_authentication_only() runs on MTC_CT {
	var charstring id := testcasename();
	var smdpp_ConnHdlrPars pars := f_init_pars();
	var smdpp_ConnHdlr vc_conn;

	f_init(id);
	vc_conn := f_start_handler(refers(f_TC_rsp_authentication_only), pars);
	vc_conn.done;
	setverdict(pass);
}

testcase TC_rsp_asn1_validation() runs on MTC_CT {
	var charstring id := testcasename();
	var smdpp_ConnHdlrPars pars := f_init_pars();
	var smdpp_ConnHdlr vc_conn;

	f_init(id);
	vc_conn := f_start_handler(refers(f_TC_rsp_asn1_validation), pars);
	vc_conn.done;
	setverdict(pass);
}

control {
	execute(TC_rsp_complete_flow());
	// execute(TC_rsp_authentication_only());
	// execute(TC_rsp_asn1_validation());
}

}