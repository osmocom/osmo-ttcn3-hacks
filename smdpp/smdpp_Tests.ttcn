testcase TC_first_experiment() runs on MTC_CT {
	var charstring id := testcasename();
	var smdpp_ConnHdlrPars pars := f_init_pars();
	var smdpp_ConnHdlr vc_conn;
	f_init(id);
	vc_conn := f_start_handler(refers(f_TC_first_experiment), pars);
	vc_conn.done;
	setverdict(pass);
}

control {
	execute ( TC_first_experiment() );
}

}