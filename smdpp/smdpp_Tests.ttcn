const charstring c_oid_rspRole_dp_auth := "2.23.146.1.2.1.4";
const charstring c_oid_rspRole_dp_pb := "2.23.146.1.2.1.5";

/* ============================================================================
 * TTCN-3 COMPONENT TYPES
 * ============================================================================ */

type component MTC_CT {
	timer g_Tguard;
	var HTTP_Server_Emulation_CT vc_HTTP_es12;
	var HTTP_Server_Emulation_CT vc_HTTP_es2p;
};

type component smdpp_ConnHdlr extends HTTP_ConnHdlr, http_CT {
	var smdpp_ConnHdlrPars g_pars_smdpp;
	var template integer g_http_client_id_es9p := omit;
	var template integer g_http_client_id_es2p := omit;

	/* C++ RSP client handle */
	var integer g_rsp_client_handle := -1;

	/* Session state */
	var octetstring g_transactionId := ''O;
	var octetstring g_euiccChallenge := ''O;
	var octetstring g_serverChallenge := ''O;
	var octetstring g_serverCert := ''O;
	var boolean g_authenticationComplete := false;
};

type record smdpp_ConnHdlrPars {
	charstring smdp_server_url,
	integer smdp_server_port,
	charstring cert_path,
	charstring cert_name_filter,
	charstring euicc_cert_path,
	charstring euicc_key_path,
	boolean test_mode
};

private function f_init_pars() runs on MTC_CT return smdpp_ConnHdlrPars {
	var smdpp_ConnHdlrPars pars := {
		smdp_server_url := "testsmdpplus1.example.com",
		smdp_server_port := 8000,
		cert_path := "./sgp26/CertificateIssuer",
		cert_name_filter := "NIST",
		euicc_cert_path := "./sgp26/eUICC/CERT_EUICC_ECDSA_NIST.der",
		euicc_key_path := "./sgp26/eUICC/SK_EUICC_ECDSA_NIST.pem",
		test_mode := false
	};
	return pars;
}

modulepar {
	HTTP_Adapter_Params mp_es9p_client := {
		http_host := "127.0.0.1",
		http_port := 8000,
		use_ssl := true
	};

	HTTP_Adapter_Params mp_es2p_client := {
		http_host := "127.0.0.1",
		http_port := 8001,
		use_ssl := true
	};

	HttpServerEmulationCfg mp_es12_server := {
		http_bind_ip := "127.0.0.1",
		http_bind_port := 8002,
		use_ssl := false
	};

	HttpServerEmulationCfg mp_es2p_server := {
		http_bind_ip := "127.0.0.1",
		http_bind_port := 8003,
		use_ssl := false
	};
}

private altstep as_Tguard() runs on MTC_CT {
	[] g_Tguard.timeout {
		Misc_Helpers.f_shutdown(__BFILE__, __LINE__, fail, "Tguard timeout");
	}
}

private type function void_fn(charstring id) runs on smdpp_ConnHdlr;

private function f_init_handler(void_fn fn, charstring id, smdpp_ConnHdlrPars pars) runs on smdpp_ConnHdlr {
	g_pars_smdpp := pars;
	fn.apply(id);
}

private function f_start_handler(void_fn fn, smdpp_ConnHdlrPars pars)
runs on MTC_CT return smdpp_ConnHdlr {
	var smdpp_ConnHdlr vc_conn;
	var charstring id := testcasename();

	vc_conn := smdpp_ConnHdlr.create(id);

	if (isbound(vc_HTTP_es12)) {
		connect(vc_conn:HTTP_SRV[0], vc_HTTP_es12:CLIENT);
		connect(vc_conn:HTTP_SRV_PROC[0], vc_HTTP_es12:CLIENT_PROC);
	}

	if (isbound(vc_HTTP_es2p)) {
		connect(vc_conn:HTTP_SRV[1], vc_HTTP_es2p:CLIENT);
		connect(vc_conn:HTTP_SRV_PROC[1], vc_HTTP_es2p:CLIENT_PROC);
	}

	vc_conn.start(f_init_handler(fn, id, pars));
	return vc_conn;
}

private function f_init(charstring id, float t_guard := 60.0) runs on MTC_CT {
	g_Tguard.start(t_guard);
	activate(as_Tguard());

	vc_HTTP_es12 := HTTP_Server_Emulation_CT.create(id);
	vc_HTTP_es12.start(HTTP_Server_Emulation.main(mp_es12_server));

	vc_HTTP_es2p := HTTP_Server_Emulation_CT.create(id);
	vc_HTTP_es2p.start(HTTP_Server_Emulation.main(mp_es2p_server));
}

/* ============================================================================
 * RSP CLIENT WRAPPER FUNCTIONS
 * ============================================================================ */

private function f_rsp_client_init() runs on smdpp_ConnHdlr return boolean {
	ext_logInfo("Initializing RSP client");

	g_rsp_client_handle := ext_RSPClient_create(
		g_pars_smdpp.smdp_server_url,
		g_pars_smdpp.smdp_server_port,
		g_pars_smdpp.cert_path,
		g_pars_smdpp.cert_name_filter
	);

	if (g_rsp_client_handle < 0) {
		ext_logError("Failed to create RSP client");
		return false;
	}

	if (ext_RSPClient_loadEUICCCertificate(g_rsp_client_handle, g_pars_smdpp.euicc_cert_path) != 0) {
		ext_logError("Failed to load eUICC certificate");
		f_rsp_client_cleanup();
		return false;
	}

	if (ext_RSPClient_loadEUICCKeyPair(g_rsp_client_handle, g_pars_smdpp.euicc_key_path) != 0) {
		ext_logError("Failed to load eUICC private key");
		f_rsp_client_cleanup();
		return false;
	}

	if (ext_RSPClient_setTestMode(g_rsp_client_handle, g_pars_smdpp.test_mode) != 0) {
		ext_logError("Failed to set test mode");
		f_rsp_client_cleanup();
		return false;
	}

	ext_logInfo("RSP client initialized with handle: " & int2str(g_rsp_client_handle));
	return true;
}

private function f_rsp_client_cleanup() runs on smdpp_ConnHdlr {
	if (g_rsp_client_handle >= 0) {
		ext_RSPClient_destroy(g_rsp_client_handle);
		g_rsp_client_handle := -1;
	}
}

/* ============================================================================
 * RSP PROTOCOL IMPLEMENTATION
 * ============================================================================ */

private function f_create_initiate_authentication_request() runs on smdpp_ConnHdlr
return RemoteProfileProvisioningRequest {

	/* Generate eUICC challenge using C++ crypto */
	g_euiccChallenge := ext_RSPClient_generateChallenge(g_rsp_client_handle);
	ext_logInfo("Generated eUICC challenge: " & ext_bytesToHex(g_euiccChallenge));

	/* Create EUICC_INFO1 using TTCN-3 native types */
	var EUICCInfo1 euiccInfo1 := {
		svn := '020200'O, /* SGP.22 v2.2.0 */
		euiccCiPKIdListForVerification := {
			ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
			ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
		},
		euiccCiPKIdListForSigning := {
			ext_hexToBytes("F54172BDF98A95D65CBEB88A38A1C11D800A85C3"),
			ext_hexToBytes("EE1F7178B70C23826CDCEA7BD28CEAB1874F552D")
		}
	};

	/* Create the request structure */
	var RemoteProfileProvisioningRequest request := {
		initiateAuthenticationRequest := {
			euiccChallenge := g_euiccChallenge,
			smdpAddress := g_pars_smdpp.smdp_server_url,
			euiccInfo1 := euiccInfo1
		}
	};

	ext_logInfo("Created initiateAuthentication request");
	return request;
}

private function f_validate_initiate_authentication_response(RemoteProfileProvisioningResponse response)
runs on smdpp_ConnHdlr return boolean {

	if (not ispresent(response.initiateAuthenticationResponse)) {
		ext_logError("No initiateAuthenticationResponse in response");
		return false;
	}

	if (not ispresent(response.initiateAuthenticationResponse.initiateAuthenticationOk)) {
		ext_logError("Authentication failed - no OK response");
		return false;
	}

	var InitiateAuthenticationOkEs9 authOk := response.initiateAuthenticationResponse.initiateAuthenticationOk;

	/* Store session data */
	g_transactionId := authOk.transactionId;
	g_serverCert := enc_Certificate(authOk.serverCertificate);

	ext_logInfo("Received transaction ID: " & ext_bytesToHex(g_transactionId));

	/* Validate transaction ID match */
	if (authOk.serverSigned1.transactionId != g_transactionId) {
		ext_logError("Transaction ID mismatch");
		return false;
	}

	/* Validate eUICC challenge match */
	if (authOk.serverSigned1.euiccChallenge != g_euiccChallenge) {
		ext_logError("eUICC challenge mismatch");
		return false;
	}

	/* Store server challenge */
	g_serverChallenge := authOk.serverSigned1.serverChallenge;

	// log(authOk);
	/* Validate server signature using C++ crypto */
	if (not ext_RSPClient_verifyServerSignature(g_rsp_client_handle, enc_ServerSigned1(authOk.serverSigned1), authOk.serverSignature1, g_serverCert)) {
		ext_logError("Server signature validation failed");
		return false;
	}

	ext_logInfo("Authentication response validation successful");
	g_authenticationComplete := true;
	return true;
}

private function f_create_get_bound_profile_package_request(octetstring smdpSignature2) runs on smdpp_ConnHdlr
return RemoteProfileProvisioningRequest {

	// if (not g_authenticationComplete) {
	// 	ext_logError("Authentication not complete");
	// 	return omit;
	// }

	/* Generate eUICC one-time public key using C++ crypto */
	var octetstring euiccOtpk := ext_RSPClient_generateEUICCOtpk(g_rsp_client_handle);

	/* Create EUICC_SIGNED2 using TTCN-3 native types */
	var EUICCSigned2 euiccSigned2 := {
		transactionId := g_transactionId,
		euiccOtpk := euiccOtpk,
		hashCc := omit
	};

	var octetstring euiccSigned2Data := enc_EUICCSigned2(euiccSigned2);
	var octetstring concatdata := euiccSigned2Data & smdpSignature2;
	var octetstring euiccSignature2 := ext_RSPClient_signDataWithEUICC(g_rsp_client_handle, concatdata);

	/* Create PrepareDownloadResponse */
	var PrepareDownloadResponse prepareDownloadResponse := {
		downloadResponseOk := {
			euiccSigned2 := euiccSigned2,
			euiccSignature2 := euiccSignature2
		}
	};

	/* Create the request */
	var RemoteProfileProvisioningRequest request := {
		getBoundProfilePackageRequest := {
			transactionId := g_transactionId,
			prepareDownloadResponse := prepareDownloadResponse
		}
	};

	ext_logInfo("Created getBoundProfilePackage request");
	return request;
}

private function f_validate_get_bound_profile_package_response(RemoteProfileProvisioningResponse response)
runs on smdpp_ConnHdlr return boolean {

	if (not ispresent(response.getBoundProfilePackageResponse)) {
		ext_logError("No getBoundProfilePackageResponse in response");
		return false;
	}

	if (not ispresent(response.getBoundProfilePackageResponse.getBoundProfilePackageOk)) {
		ext_logError("getBoundProfilePackage failed - no OK response");
		return false;
	}

	var GetBoundProfilePackageOk packageOk := response.getBoundProfilePackageResponse.getBoundProfilePackageOk;

	/* Validate transaction ID match */
	if (packageOk.transactionId != g_transactionId or packageOk.boundProfilePackage.initialiseSecureChannelRequest.transactionId != g_transactionId) {
		ext_logError("Transaction ID mismatch in getBoundProfilePackage response");
		return false;
	}

	if (not ispresent(packageOk.boundProfilePackage)) {
		ext_logError("No boundProfilePackage in response");
		return false;
	}

	/* Decode BoundProfilePackage using TTCN-3 native decoder */
	var BoundProfilePackage boundPackage := packageOk.boundProfilePackage;

	/* Validate structure */
	if (not ispresent(boundPackage.initialiseSecureChannelRequest)) {
		ext_logError("Missing initialiseSecureChannelRequest");
		return false;
	}

	if (not ispresent(boundPackage.firstSequenceOf87)) {
		ext_logError("Missing firstSequenceOf87");
		return false;
	}

	if (not ispresent(boundPackage.sequenceOf88)) {
		ext_logError("Missing sequenceOf88");
		return false;
	}

	if (not ispresent(boundPackage.sequenceOf86)) {
		ext_logError("Missing sequenceOf86");
		return false;
	}

	ext_logInfo("getBoundProfilePackage response validation successful");
	return true;
}

/* ============================================================================
 * HTTP COMMUNICATION
 * ============================================================================ */

template (value) HeaderLines ts_rsp_HTTP_Header := {
	{ header_name := "User-Agent", header_value := "TTCN3 smdpp testsuite" },
	{ header_name := "X-Admin-Protocol", header_value := "gsma/rsp/v2.5.0" },
	{ header_name := "Content-Type", header_value := "application/json;charset=UTF-8" }
};

/* Send ES9+ HTTP request */
private function f_es9p_send(RemoteProfileProvisioningRequest es9p_req) runs on smdpp_ConnHdlr {
	var charstring es9p_req_enc;
	var charstring es9p_url;

	if (ispresent(es9p_req.initiateAuthenticationRequest)) {
		es9p_url := "/gsma/rsp2/es9plus/initiateAuthentication";
	} else if (ispresent(es9p_req.getBoundProfilePackageRequest)) {
		es9p_url := "/gsma/rsp2/es9plus/getBoundProfilePackage";
	} else if (ispresent(es9p_req.authenticateClientRequest)) {
		es9p_url := "/gsma/rsp2/es9plus/authenticateClient";
	} else if (ispresent(es9p_req.handleNotification)) {
		es9p_url := "/gsma/rsp2/es9plus/handleNotification";
	} else if (ispresent(es9p_req.cancelSessionRequestEs9)) {
		es9p_url := "/gsma/rsp2/es9plus/cancelSession";
	} else {
		setverdict(fail, "unknown JSON ES9+ function");
	}

	enc_RemoteProfileProvisioningRequest_to_JSON(es9p_req, es9p_req_enc);

	f_http_tx_request(url := es9p_url,
			  method := "POST",
			  body := es9p_req_enc,
			  custom_hdr := valueof(ts_rsp_HTTP_Header),
			  client_id := g_http_client_id_es9p,
			  http_pars := mp_es9p_client);
}

/* Receive ES9+ HTTP response */
private function f_es9p_receive(template RemoteProfileProvisioningResponse expected_es9p_res := omit)
runs on smdpp_ConnHdlr return template RemoteProfileProvisioningResponse {
	var RemoteProfileProvisioningResponse es9p_res;
	var HTTPMessage response_http;
	response_http := f_http_rx_response(exp := ?,
					    client_id := g_http_client_id_es9p,
					    keep_connection := true);

	if (istemplatekind(g_http_client_id_es9p, "omit")) {
		/* Memorize client_id of the first request. The client_id will identify the HTTP connection
		 * in all consecutive requests. */
		g_http_client_id_es9p := f_http_client_id_from_http_response(response_http);
	} else if (valueof(g_http_client_id_es9p) != valueof(f_http_client_id_from_http_response(response_http))) {
		/* The client_id must not change. A sudden change of the client_id may indicate an interrupted
		 * HTTP connection. This must not happen unexpectetly. */
		setverdict(fail, "unexpected ES9+ HTTP connection");
	}

	if (ispresent(response_http.response)) {
		dec_RemoteProfileProvisioningResponse_from_JSON(response_http.response.body, es9p_res);
		if (not istemplatekind(expected_es9p_res, "omit")) {
			if (not match(es9p_res, expected_es9p_res)) {
				setverdict(fail, "unexpected response from SM-DP+ on ES9+");
			}
		}

		if (isvalue(es9p_res)) {
			return es9p_res;
		}
		return omit
	} else {
		setverdict(fail,
			   "unexpected ES9+ response, the HTTP body did either contain no or a non binary response");
		return omit;
	}
}

/* Perform one ES9+ HTTP request/response cycle */
private function f_es9p_client_transceive(RemoteProfileProvisioningRequest es9p_req,
					  template RemoteProfileProvisioningResponse expected_es9p_res := omit)
runs on smdpp_ConnHdlr return template RemoteProfileProvisioningResponse {
	var template RemoteProfileProvisioningResponse es9p_res
	f_es9p_send(es9p_req);
	es9p_res := f_es9p_receive();
	if (not istemplatekind(expected_es9p_res, "omit")) {
		if (not match(valueof(es9p_res), expected_es9p_res)) {
			setverdict(fail, "unexpected response from SM-DP+ on ES9+");
		}
	}
	return es9p_res;
}


private function f_send_es9p_request(charstring endpoint, charstring jsonBody) runs on smdpp_ConnHdlr return charstring {
	f_http_tx_request(url := endpoint,
	                  method := "POST",
	                  body := jsonBody,
	                  custom_hdr := valueof(ts_rsp_HTTP_Header),
	                  client_id := g_http_client_id_es9p,
	                  http_pars := mp_es9p_client);

	var HTTPMessage response_http := f_http_rx_response(exp := ?,
	                                                   client_id := g_http_client_id_es9p,
	                                                   keep_connection := true);

	if (istemplatekind(g_http_client_id_es9p, "omit")) {
		g_http_client_id_es9p := f_http_client_id_from_http_response(response_http);
	}

	if (ispresent(response_http.response)) {
		ext_logInfo("HTTP " & int2str(response_http.response.statuscode) &
		           " response, body length: " & int2str(lengthof(response_http.response.body)));
		return response_http.response.body;
	} else {
		ext_logError("No HTTP response body");
		return "";
	}
}

private function f_perform_es9p_request_response(RemoteProfileProvisioningRequest request,
                                               charstring endpoint) runs on smdpp_ConnHdlr
return RemoteProfileProvisioningResponse {

	/* Encode request to JSON */
	var charstring requestJson;
	enc_RemoteProfileProvisioningRequest_to_JSON(request, requestJson);

	ext_logInfo("Sending " & endpoint & " request");
	ext_logDebug("Request JSON length: " & int2str(lengthof(requestJson)));

	/* Send HTTP request */
	var charstring responseJson := f_send_es9p_request(endpoint, requestJson);

	// if (lengthof(responseJson) == 0) {
	// 	ext_logError("Empty response received");
	// 	return omit;
	// }

	/* Decode JSON response */
	var RemoteProfileProvisioningResponse response;
	dec_RemoteProfileProvisioningResponse_from_JSON(responseJson, response);

	return response;
}

/* ============================================================================
 * TEST CASE IMPLEMENTATIONS
 * ============================================================================ */

function to_upper(in charstring str) return charstring {
    return f_str_toupper(str);
}


private function enc_InitialiseSecureChannelRequest(InitialiseSecureChannelRequest req) return octetstring {
    // This is a simplified encoding - real implementation needs proper BER-TLV
    var octetstring result := 'BF23'O; // Tag [35]

    // Encode content
    var octetstring content := ''O;

    // remoteOpId [2]
    content := content & '8201'O & int2oct(req.remoteOpId, 1);

    // transactionId [0]
    content := content & '80'O & int2oct(lengthof(req.transactionId), 1) & req.transactionId;

    // controlRefTemplate [6] IMPLICIT
    var octetstring crt := req.controlRefTemplate.keyType &
                          req.controlRefTemplate.keyLen &
                          '84'O & int2oct(lengthof(req.controlRefTemplate.hostId), 1) &
                          req.controlRefTemplate.hostId;
    content := content & 'A6'O & int2oct(lengthof(crt), 1) & crt;

    // smdpOtpk [APPLICATION 73]
    content := content & '5F49'O & int2oct(lengthof(req.smdpOtpk), 1) & req.smdpOtpk;

    // Length encoding
    if (lengthof(content) < 128) {
        result := result & int2oct(lengthof(content), 1) & content;
    } else {
        // Long form
        var integer len := lengthof(content);
        var octetstring lenOct := int2oct(len, 2);
        result := result & '82'O & lenOct & content;
    }

    return result;
}

private function f_validate_session_keys(octetstring sharedSecret,
                                       octetstring hostId) runs on smdpp_ConnHdlr
return boolean {
    var octetstring sEnc, sMac, sDek;

    if (not ext_Crypto_deriveSessionKeys(sharedSecret, hostId, sEnc, sMac, sDek)) {
        ext_logError("Failed to derive session keys");
        return false;
    }

    // Verify all keys are 16 bytes (AES-128)
    if (lengthof(sEnc) != 16 or lengthof(sMac) != 16 or lengthof(sDek) != 16) {
        ext_logError("Invalid session key lengths");
        return false;
    }

    ext_logInfo("Session keys derived successfully");
    ext_logDebug("S-ENC: " & oct2str(sEnc));
    ext_logDebug("S-MAC: " & oct2str(sMac));
    ext_logDebug("S-DEK: " & oct2str(sDek));

    return true;
}

private function f_validate_profile_segments(BoundProfilePackage bpp,
                                           octetstring sEnc,
                                           octetstring sMac) runs on smdpp_ConnHdlr
return boolean {
    // Validate firstSequenceOf87 (ConfigureISDP)
    for (var integer i := 0; i < lengthof(bpp.firstSequenceOf87); i := i + 1) {
        var octetstring segment := bpp.firstSequenceOf87[i];
        if (lengthof(segment) < 16 or lengthof(segment) mod 16 != 0) {
            ext_logError("Invalid ConfigureISDP segment size");
            return false;
        }

        if (not ext_Crypto_verifyEncryptedProfileData(segment, sEnc, sMac)) {
            ext_logError("ConfigureISDP segment validation failed");
            return false;
        }
    }

    // Validate sequenceOf88 (StoreMetadata)
    for (var integer i := 0; i < lengthof(bpp.sequenceOf88); i := i + 1) {
        var octetstring segment := bpp.sequenceOf88[i];
        if (lengthof(segment) < 16 or lengthof(segment) mod 16 != 0) {
            ext_logError("Invalid StoreMetadata segment size");
            return false;
        }

        if (not ext_Crypto_verifyEncryptedProfileData(segment, sEnc, sMac)) {
            ext_logError("StoreMetadata segment validation failed");
            return false;
        }
    }

    // Validate sequenceOf86 (LoadProfileElements)
    for (var integer i := 0; i < lengthof(bpp.sequenceOf86); i := i + 1) {
        var octetstring segment := bpp.sequenceOf86[i];
        if (lengthof(segment) < 16 or lengthof(segment) mod 16 != 0) {
            ext_logError("Invalid LoadProfileElements segment size");
            return false;
        }

        if (not ext_Crypto_verifyEncryptedProfileData(segment, sEnc, sMac)) {
            ext_logError("LoadProfileElements segment validation failed");
            return false;
        }
    }

    return true;
}


external function encode_DER_InitialiseSecureChannelRequest_ver(
  in InitialiseSecureChannelRequest_ver pdu
) return octetstring
with { extension "prototype(convert) encode(BER:BER_ENCODE_DER)" };



