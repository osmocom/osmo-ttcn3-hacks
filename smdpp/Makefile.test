# Makefile for standalone certificate chain verification test tool

CXX = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -O2 `pkg-config --cflags openssl libcjson jansson libcurl`
LDFLAGS = `pkg-config --libs openssl libcjson jansson libcurl`

TARGET = test_cert_chain
SOURCE = test_cert_chain.cpp

all: $(TARGET)

$(TARGET): $(SOURCE)
	$(CXX) $(CXXFLAGS) -o $@ $< $(LDFLAGS)

clean:
	rm -f $(TARGET)

run: $(TARGET)
	./$(TARGET)

run-verbose: $(TARGET)
	./$(TARGET) -v

.PHONY: all clean run run-verbose