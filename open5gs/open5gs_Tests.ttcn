module open5gs-tests {

import from JSON_Generic all;

type component test_CT {
}

testcase TC_Encode_Decode_JSON_Generic() runs on test_CT {
  var JSON_generic_val pdu;
  var octetstring encoded;
  var JSON_generic_val decoded_pdu;
  
  // 1. Baue das JSON-Objekt (als Record of Key-Value)
  pdu := {
    JSON_object := {
      { key := "name", val := { JSON_string := "Andreas" } },
      { key := "age", val := { JSON_integer := 42 } }
    }
  };

  // 2. JSON encodieren
  encoded := f_enc_JSON(pdu);
  log("Encoded JSON: ", encoded);

  // 3. JSON decodieren
  var integer decode_result := f_dec_JSON(encoded, decoded_pdu);
  log("Decoded JSON PDU: ", decoded_pdu);
}

control {
  execute(TC_Encode_Decode_JSON_Generic());
}

}
