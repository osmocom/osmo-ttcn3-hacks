### end of section generated by contrib/update_meson_build.py ###

pp_targets = {}
lib_targets = {}
lib_ttcn_inputs = {}

###
### Libraries
###
foreach lib : libs
  message('Generating library targets: ' + lib['name'])
  assert('sources' in lib, 'missing section: "sources"')

  target_name = 'cc_lib' + lib['name']
  ttcn_inputs = []
  # CC files from this library
  # HH files from this library + depends
  cc_hh_files_from_ttcn = []
  cc_files_other = []

  sources_all = lib['sources']
  if 'sources_deps' in lib
    sources_all += lib['sources_deps']
  endif

  foreach source : sources_all
    if source.endswith('.ttcnpp')
      if source not in pp_targets
        output = fs.stem(source) + '.ttcn'
        pp_target = custom_target(
          output,
          input: source,
          output: output,
          command: [cpp,
                     '-x', 'c',
                     '-nostdinc' ] + \
                    cpp_flags + \
                    ['@INPUT@',
                     '-o', '@OUTPUT@'],
          )
        pp_targets += {source: pp_target}
      endif
      pp_target = pp_targets[source]
      if pp_target not in ttcn_inputs
        ttcn_inputs += [pp_target]
      endif
    elif source.endswith('.ttcn') or source.endswith('.asn')
      if source not in ttcn_inputs
        ttcn_inputs += [source]
      endif
    elif source.endswith('.cc') or source.endswith('.c')
      cc_files_other += [source]
    else
      assert(false, 'source has unexpected file extension: ' + source)
    endif

  endforeach

  foreach source : lib['sources']
    # The ttcn3_compiler needs all the .ttcn files of the module to be built
    # (sources) and all its dependencies (sources_deps) as input. We give
    # them, but only tell meson about the .cc files for the module as output
    # (not the dependencies' .cc files!) so we don't end up compiling the
    # dependencies over and over again.
    if not source.endswith('.cc') and not source.endswith('.c')
      cc_hh_files_from_ttcn += [target_name + '_' + fs.stem(source) + '.cc']
      foreach i : range(1, ttcn3_split_file_count)
        cc_hh_files_from_ttcn += [target_name + '_' + fs.stem(source) + '_part_' + i.to_string() + '.cc']
      endforeach
    endif
  endforeach

  foreach source : sources_all
    if not source.endswith('.cc') and not source.endswith('.c')
      cc_hh_files_from_ttcn += [target_name + '_' + fs.stem(source) + '.hh']
    endif
  endforeach

  if ttcn_inputs.length() > 0 and cc_hh_files_from_ttcn.length() > 0
    ttcn3_to_cc_target = custom_target(target_name,
      input: ttcn_inputs,
      output : cc_hh_files_from_ttcn,
      command : ['contrib/ttcn3_compiler_wrapper.sh', target_name, ttcn3_compiler] + ttcn3_compiler_flags + ['@INPUT@'],
    )
  else
    ttcn3_to_cc_target = cc_hh_files_from_ttcn
  endif

  link_deps = []
  cxx_flags = []
  if 'link_deps' in lib
    foreach link_dep_name : lib['link_deps']
      assert(link_dep_name in lib_targets, 'library must come' \
        + ' after its dependency ' + link_dep_name)
      link_deps += lib_targets[link_dep_name]
      # Use -I instead of adding it to include_directories, so meson does not
      # require the directory to exist when the static_library target gets
      # created
      cxx_flags += ['-I_cc_lib' + link_dep_name]
    endforeach
  endif


  lib_targets += {lib['name']: static_library(lib['name'],
    [ttcn3_to_cc_target, cc_files_other],
    include_directories: cc_incdir,
    cpp_args: cxx_flags,
    c_args: cxx_flags,
    link_args: link_flags,
    link_with: link_deps,
    )}
  lib_ttcn_inputs += {lib['name']: ttcn_inputs}

endforeach

###
### Testsuites
###
foreach testsuite_name : testsuites.keys()
  testsuite = testsuites[testsuite_name]
  message('Generating testsuite targets: ' + testsuite_name)
  target_name = 'cc_' + testsuite_name

  ttcn_inputs = []
  link_deps = []
  foreach source : testsuite['sources']
    ttcn_inputs += [source]
  endforeach
  foreach dep : testsuite['link_deps']
    assert(dep in lib_ttcn_inputs, 'link_dep ' + dep + ' not found in libs')
    foreach ttcn_input : lib_ttcn_inputs[dep]
      if ttcn_input not in ttcn_inputs
        ttcn_inputs += ttcn_input
      endif
    endforeach
    link_deps += lib_targets[dep]
  endforeach

  cc_files_from_ttcn = []
  foreach source : testsuite['sources']
    cc_files_from_ttcn += [target_name + '_' + fs.stem(source) + '.cc']
    foreach i : range(1, ttcn3_split_file_count)
      cc_files_from_ttcn += [target_name + '_' + fs.stem(source) + '_part_' + i.to_string() + '.cc']
    endforeach
  endforeach

  ttcn3_to_cc_target = custom_target(target_name,
    input: ttcn_inputs,
    output : cc_files_from_ttcn,
    command : ['contrib/ttcn3_compiler_wrapper.sh', target_name, ttcn3_compiler] + ttcn3_compiler_flags + ['@INPUT@'],
  )

  executable(testsuite_name,
    ttcn3_to_cc_target,
    include_directories: cc_incdir,
    link_args: link_flags,
    link_with: link_deps,
    )

endforeach
