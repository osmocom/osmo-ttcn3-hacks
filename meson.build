project('Osmocom TTCN-3 Testsuites', ['cpp', 'c'])
fs = import('fs')

# TTCN3 -> CC compiler
ttcn3_compiler = find_program('ttcn3_compiler')
ttcn3_split_file_count = 8
ttcn3_compiler_flags = [
  '-q',
  '-L',
  '-U', ttcn3_split_file_count.to_string(),
  '-D',
  ]

# Preprocessor for ttcnpp files
cpp = find_program('cpp')
cpp_flags = [
    '-DIPA_EMULATION_CTRL',
    '-DIPA_EMULATION_RSL',
    '-DUSE_MTP3_DISTRIBUTOR',
  ]

# C++ compiler
cc_incdir = include_directories('/usr/include/titan',
                             './deps/titan.TestPorts.IPL4asp/src/')

link_flags = [
  '-L/usr/lib/titan',
  '-lttcn3-parallel-dynamic',
  '-lcrypto',
  '-lxml2',
  ]

add_project_arguments('-DLINUX', language : 'cpp')

# Silence warning from /usr/include/titan/cversion.h that really clutters the
# output
add_project_arguments('-DMAKEDEPEND_RUN', language : 'cpp')


