    function f_decodeCancelSessionResp(in charstring jsonStr) return CancelSession_Response {
        var CancelSession_Response resp := {
            transactionId := "",
            functionExecutionStatus := ""
        };

        var JSON_PDU jsonResp := f_safe_dec_JSON(char2uchar(jsonStr));

        if (ischosen(jsonResp.json_object)) {
            for (var integer i := 0; i < sizeof(jsonResp.json_object); i := i + 1) {
                if (jsonResp.json_object[i].json_name == "transactionId" and
                    ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.transactionId := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "functionExecutionStatus" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.functionExecutionStatus := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
            }
        }

        return resp;
    }

    // Parse Profile Metadata with proper JSON handling
    function f_parseProfileMetadata(in charstring metadataJson) return ProfileMetadata {
        var ProfileMetadata metadata := {
            iccid := "",
            serviceProviderName := "",
            profileName := "",
            profileClass := "",
            profileState := "",
            iconType := omit,
            icon := omit,
            profileOwner := omit,
            pol2Rules := omit,
            topLevelOperatorConnectivity := omit
        };

        var JSON_PDU jsonData := f_safe_dec_JSON(metadataJson);

        if (ischosen(jsonData.json_object)) {
            for (var integer i := 0; i < sizeof(jsonData.json_object); i := i + 1) {
                if (jsonData.json_object[i].json_name == "iccid" and
                    ischosen(jsonData.json_object[i].json_value.json_string)) {
                    metadata.iccid := unichar2char(jsonData.json_object[i].json_value.json_string);
                }
                else if (jsonData.json_object[i].json_name == "serviceProviderName" and
                         ischosen(jsonData.json_object[i].json_value.json_string)) {
                    metadata.serviceProviderName := unichar2char(jsonData.json_object[i].json_value.json_string);
                }
                else if (jsonData.json_object[i].json_name == "profileName" and
                         ischosen(jsonData.json_object[i].json_value.json_string)) {
                    metadata.profileName := unichar2char(jsonData.json_object[i].json_value.json_string);
                }
                else if (jsonData.json_object[i].json_name == "profileClass" and
                         ischosen(jsonData.json_object[i].json_value.json_string)) {
                    metadata.profileClass := unichar2char(jsonData.json_object[i].json_value.json_string);
                }
                else if (jsonData.json_object[i].json_name == "profileState" and
                         ischosen(jsonData.json_object[i].json_value.json_string)) {
                    metadata.profileState := unichar2char(jsonData.json_object[i].json_value.json_string);
                }
                else if (jsonData.json_object[i].json_name == "iconType" and
                         ischosen(jsonData.json_object[i].json_value.json_string)) {
                    metadata.iconType := unichar2char(jsonData.json_object[i].json_value.json_string);
                }
                else if (jsonData.json_object[i].json_name == "profileOwner" and
                         ischosen(jsonData.json_object[i].json_value.json_string)) {
                    metadata.profileOwner := unichar2char(jsonData.json_object[i].json_value.json_string);
                }
                else if (jsonData.json_object[i].json_name == "pol2Rules" and
                         ischosen(jsonData.json_object[i].json_value.json_array)) {
                    var JSON_Array rulesArray := jsonData.json_object[i].json_value.json_array;
                    metadata.pol2Rules := {};

                    for (var integer j := 0; j < sizeof(rulesArray); j := j + 1) {
                        if (ischosen(rulesArray[j].json_object)) {
                            var PolicyRule rule := {
                                policyRuleId := "",
                                ruleFormat := "",
                                policyRuleContent := ""
                            };

                            var JSON_Object ruleObj := rulesArray[j].json_object;
                            for (var integer k := 0; k < sizeof(ruleObj); k := k + 1) {
                                if (ruleObj[k].json_name == "policyRuleId" and
                                    ischosen(ruleObj[k].json_value.json_string)) {
                                    rule.policyRuleId := unichar2char(ruleObj[k].json_value.json_string);
                                }
                                else if (ruleObj[k].json_name == "ruleFormat" and
                                         ischosen(ruleObj[k].json_value.json_string)) {
                                    rule.ruleFormat := unichar2char(ruleObj[k].json_value.json_string);
                                }
                                else if (ruleObj[k].json_name == "policyRuleContent" and
                                         ischosen(ruleObj[k].json_value.json_string)) {
                                    rule.policyRuleContent := unichar2char(ruleObj[k].json_value.json_string);
                                }
                            }

                            metadata.pol2Rules[sizeof(metadata.pol2Rules)] := rule;
                        }
                    }
                }
            }
        }

        return metadata;
    }

}