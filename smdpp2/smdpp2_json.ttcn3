    function f_encodeCancelSessionReq(in CancelSession_Request req) return charstring {
        var JSON_PDU jsonReq;
        var JSON_Object jsonObj := {};

        jsonObj[0] := {
            json_name := "transactionId",
            json_value := { json_string := char2uchar(req.transactionId) }
        };

        jsonObj[1] := {
            json_name := "cancelSessionReason",
            json_value := { json_string := char2uchar(req.cancelSessionReason) }
        };

        jsonReq.json_object := jsonObj;
        var octetstring octJson := enc_JSON(jsonReq);
        return oct2char(octJson);
    }



    // JSON decoding functions using proper JSON_PDU
    function f_decodeInitiateAuthResp(in charstring jsonStr) return InitiateAuthentication_Response {
        var InitiateAuthentication_Response resp := {
            transactionId := "",
            serverSigned1 := "",
            serverSignature1 := "",
            euiccCiPKIdToBeUsed := "",
            serverCertificate := ""
        };

        var JSON_PDU jsonResp := f_safe_dec_JSON(char2uchar(jsonStr));

        if (ischosen(jsonResp.json_object)) {
            for (var integer i := 0; i < sizeof(jsonResp.json_object); i := i + 1) {
                if (jsonResp.json_object[i].json_name == "transactionId" and
                    ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.transactionId := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "serverSigned1" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.serverSigned1 := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "serverSignature1" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.serverSignature1 := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "euiccCiPKIdToBeUsed" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.euiccCiPKIdToBeUsed := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "serverCertificate" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.serverCertificate := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
            }
        }

        return resp;
    }

    function f_decodeAuthClientResp(in charstring jsonStr) return AuthenticateClient_Response {
        var AuthenticateClient_Response resp := {
            transactionId := "",
            profileMetadata := "",
            smdpSigned2 := "",
            smdpSignature2 := "",
            smdpCertificate := "",
            errorResult := omit
        };

        var JSON_PDU jsonResp := f_safe_dec_JSON(char2uchar(jsonStr));

        if (ischosen(jsonResp.json_object)) {
            for (var integer i := 0; i < sizeof(jsonResp.json_object); i := i + 1) {
                if (jsonResp.json_object[i].json_name == "transactionId" and
                    ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.transactionId := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "profileMetadata" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.profileMetadata := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "smdpSigned2" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.smdpSigned2 := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "smdpSignature2" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.smdpSignature2 := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "smdpCertificate" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.smdpCertificate := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
                else if (jsonResp.json_object[i].json_name == "errorResult" and
                         ischosen(jsonResp.json_object[i].json_value.json_string)) {
                    resp.errorResult := uchar2char(jsonResp.json_object[i].json_value.json_string);
                }
            }
        }

        return resp;
    }

