        jsonObj[1] := {
            json_name := "prepareDownloadResponse",
            json_value := { json_string := char2uchar(req.prepareDownloadResponse) }
        };

        jsonReq.json_object := jsonObj;
        var octetstring octJson := enc_JSON(jsonReq);
        return oct2char(octJson);
    }

    function f_encodeHandleNotificationReq(in HandleNotification_Request req) return charstring {
        var JSON_PDU jsonReq;
        var JSON_Object jsonObj := {};

        jsonObj[0] := {
            json_name := "pendingNotification",
            json_value := { json_string := char2uchar(req.pendingNotification) }
        };

        jsonObj[1] := {
            json_name := "euiccSignPNtoken",
