module smdpp2_Tests {

// Module parameters for configuration
modulepar {
  charstring tsp_es9p_base_url := "";
  charstring tsp_server_ca_cert := "";
  charstring tsp_certificate_path := ".";
  charstring tsp_euicc_certificate := "CERT_EUICC_ECDSA_NIST.der";
  charstring tsp_euicc_private_key := "SK_EUICC_ECDSA_NIST.pem";
  charstring tsp_eum_certificate := "CERT_EUM_ECDSA_NIST.der";
  charstring tsp_ci_certificate := "CERT_CI_ECDSA_NIST.der";
  charstring tsp_output_path := ".";
  // Command parameters
  charstring tsp_command := "";
  charstring tsp_matching_id := "";
  charstring tsp_confirmation_code := "";
  integer tsp_sequence_nr := 0;
  charstring tsp_operation := "";
  charstring tsp_notification_address := "";
  charstring tsp_iccid := "";
  charstring tsp_transaction_id := "";
  charstring tsp_smdpp_oid := "";
  charstring tsp_isdp_aid := "";
  charstring tsp_sima_response := "";
}

// Enumerated types
type enumerated ProfileManagementOperation {
  PMO_DOWNLOAD(0),
  PMO_INSTALL(1),
  PMO_ENABLE(2),
  PMO_DISABLE(3),
  PMO_DELETE(4)
}

// ASN.1 type definitions with DER encoding
type octetstring ASN1_Certificate with { encode "DER" }
type octetstring ASN1_PrivateKey with { encode "DER" }

// Complex ASN.1 structures
type record ASN1_EuiccInfo1 {
  octetstring svn,
  record of octetstring euiccCiPKIdListForVerification,
  record of octetstring euiccCiPKIdListForSigning
} with { encode "DER" }

type record ASN1_EuiccInfo2 {
  octetstring profileVersion,
  octetstring svn,
  octetstring euiccFirmwareVer,
  octetstring extCardResource,
  record {
    octetstring uiccCapability,
    integer bitStringLength
  } uiccCapability,
  octetstring javacardVersion,
  octetstring globalplatformVersion,
  record {
    octetstring rspCapability,
    integer bitStringLength
  } rspCapability,
  record of octetstring euiccCiPKIdListForVerification,
  record of octetstring euiccCiPKIdListForSigning,
  octetstring ppVersion,
  charstring sasAcreditationNumber optional,
  octetstring euiccCategory optional,
  octetstring forbiddenProfilePolicyRules optional,
  octetstring certificationDataObject optional
} with { encode "DER" }

type record ASN1_DeviceInfo {
  octetstring tac,
  record {} deviceCapabilities,
  octetstring imei optional
} with { encode "DER" }

type record ASN1_CtxParamsForCommonAuthentication {
  charstring matchingId,
  ASN1_DeviceInfo deviceInfo
} with { encode "DER" }

type union ASN1_CtxParams1 {
  ASN1_CtxParamsForCommonAuthentication ctxParamsForCommonAuthentication
} with { encode "DER" }

type record ASN1_EuiccSigned1 {
  octetstring transactionId,
  charstring serverAddress,
  octetstring serverChallenge,
  ASN1_EuiccInfo2 euiccInfo2,
  ASN1_CtxParams1 ctxParams1
} with { encode "DER" }

type record ASN1_EuiccSigned2 {
  octetstring transactionId,
  octetstring euiccOtpk,
  octetstring hashCc optional
} with { encode "DER" }

type record ASN1_NotificationMetadata {
  integer seqNumber,
  bitstring profileManagementOperation,
  charstring notificationAddress,
  octetstring iccid optional
} with { encode "DER" }

type record ASN1_FinalResult_SuccessResult {
  octetstring aid,
  octetstring simaResponse
} with { encode "DER" }

type union ASN1_FinalResult {
  ASN1_FinalResult_SuccessResult successResult
} with { encode "DER" }

type record ASN1_ProfileInstallationResultData {
  charstring transactionId,
  ASN1_NotificationMetadata notificationMetadata,
  charstring smdpOid,
  ASN1_FinalResult finalResult
} with { encode "DER" }

// JSON message types
type record InitiateAuthenticationRequest {
  octetstring euiccChallenge,
  ASN1_EuiccInfo1 euiccInfo1,
  charstring smdpAddress
} with { encode "JSON" }

type record ServerSigned1 {
  charstring serverAddress,
  octetstring serverChallenge,
  charstring transactionId,
  octetstring euiccCiPKIdToBeUsed,
  octetstring serverCertificate
} with { encode "JSON" }

type record InitiateAuthenticationResponse {
  ServerSigned1 serverSigned1,
  octetstring serverSignature1,
  charstring transactionId,
  octetstring euiccCiPKIdToBeUsed,
  octetstring serverCertificate
} with { encode "JSON" }

type record AuthenticateResponseOk {
  ASN1_EuiccSigned1 euiccSigned1,
  octetstring euiccSignature1,
  ASN1_Certificate euiccCertificate,
  ASN1_Certificate eumCertificate
} with { encode "JSON" }

type union AuthenticateServerResponse {
  AuthenticateResponseOk authenticateResponseOk
} with { encode "JSON" }

type record AuthenticateClientRequest {
  charstring transactionId,
  AuthenticateServerResponse authenticateServerResponse
} with { encode "JSON" }

type record SmdpSigned2 {
  octetstring bppEuiccOtpk,
  boolean ccRequiredFlag
} with { encode "JSON" }

type record AuthenticateClientResponse {
  charstring transactionId,
  record {} profileMetadata,
  SmdpSigned2 smdpSigned2,
  octetstring smdpSignature2,
  octetstring smdpCertificate
} with { encode "JSON" }

type record DownloadResponseOk {
  ASN1_EuiccSigned2 euiccSigned2,
  octetstring euiccSignature2
} with { encode "JSON" }

type union PrepareDownloadResponse {
  DownloadResponseOk downloadResponseOk
} with { encode "JSON" }

type record GetBoundProfilePackageRequest {
  charstring transactionId,
  PrepareDownloadResponse prepareDownloadResponse
} with { encode "JSON" }

type record GetBoundProfilePackageResponse {
  charstring transactionId,
  octetstring boundProfilePackage
} with { encode "JSON" }

type record ProfileInstallationResult {
  ASN1_ProfileInstallationResultData profileInstallationResultData,
  octetstring euiccSignPIR
} with { encode "JSON" }

type record OtherSignedNotification {
  ASN1_NotificationMetadata tbsOtherNotification,
  octetstring euiccNotificationSignature,
  ASN1_Certificate euiccCertificate,
  ASN1_Certificate eumCertificate
} with { encode "JSON" }

type union PendingNotification {
  ProfileInstallationResult profileInstallationResult,
  OtherSignedNotification otherSignedNotification
} with { encode "JSON" }

type record HandleNotificationRequest {
  PendingNotification pendingNotification
} with { encode "JSON" }

// Record types for external function returns
type record ECKeypairResult {
  octetstring private_key,
  octetstring public_key_raw,
  octetstring public_key_der
}

type record CertificateInfo {
  integer success,
  charstring subject,
  charstring issuer,
  octetstring public_key
}

type record BPPDecodeResult {
  integer success,
  octetstring upp,
  octetstring storeMetadataRequest,
  octetstring configureISDPRequest,
  octetstring iccid
}

// External function declarations for HTTP/TLS
external function f_curl_init() return integer;
external function f_curl_cleanup(integer handle);
external function f_curl_set_url(integer handle, charstring url) return integer;
external function f_curl_set_client_cert(integer handle, charstring cert_file, charstring key_file) return integer;
external function f_curl_set_ca_cert(integer handle, charstring ca_file) return integer;
external function f_curl_set_post_data(integer handle, charstring data) return integer;
type record of charstring StringArray;
external function f_curl_set_headers(integer handle, StringArray  headers) return integer;
external function f_curl_perform(integer handle) return charstring;
external function f_curl_get_response_code(integer handle) return integer;

// External function declarations for cryptography
external function f_ssl_load_certificate_from_file(charstring filename) return octetstring;
external function f_ssl_load_private_key_from_file(charstring filename) return octetstring;
external function f_ssl_extract_subject_serial(octetstring cert_der) return charstring;
external function f_ssl_extract_subject_pkid(octetstring cert_der) return octetstring;
external function f_ssl_ecdsa_sign(octetstring data, octetstring private_key_der) return octetstring;
external function f_ssl_ecdsa_verify(octetstring data, octetstring csignature, octetstring public_key_der) return boolean;
external function f_ssl_generate_ec_keypair(charstring curve_name) return ECKeypairResult;
external function f_ssl_ecdh_derive_key(octetstring our_private, octetstring their_public) return octetstring;
external function f_ssl_sha256(octetstring data) return octetstring;
external function f_ssl_random(integer clength) return octetstring;
external function f_ssl_decode_asn1_certificate(octetstring cert_der) return CertificateInfo;

// External function declarations for file operations
external function f_file_read_binary(charstring filename) return octetstring;
external function f_file_write_binary(charstring filename, octetstring data) return integer;
external function f_file_path_join(charstring path1, charstring path2) return charstring;

// External function declarations for ASN.1 encoding (using asn1c or similar)
external function f_asn1_encode_euicc_signed1(ASN1_EuiccSigned1 v) return octetstring;
external function f_asn1_encode_euicc_signed2(ASN1_EuiccSigned2 v) return octetstring;
external function f_asn1_encode_notification_metadata(ASN1_NotificationMetadata v) return octetstring;
external function f_asn1_encode_profile_installation_result_data(ASN1_ProfileInstallationResultData v) return octetstring;

// External function declarations for JSON encoding
external function f_json_encode_initiate_auth_request(InitiateAuthenticationRequest v) return charstring;
external function f_json_decode_initiate_auth_response(charstring json) return InitiateAuthenticationResponse;
external function f_json_encode_auth_client_request(AuthenticateClientRequest v) return charstring;
external function f_json_decode_auth_client_response(charstring json) return AuthenticateClientResponse;
external function f_json_encode_get_bpp_request(GetBoundProfilePackageRequest v) return charstring;
external function f_json_decode_get_bpp_response(charstring json) return GetBoundProfilePackageResponse;
external function f_json_encode_handle_notification_request(HandleNotificationRequest v) return charstring;

// External function for BPP processing
external function f_bpp_decode(octetstring bpp_bin, octetstring euicc_otsk, charstring eid) return BPPDecodeResult;

// Utility functions
function f_hex2nibbleswap(charstring hex_str) return charstring {
  var charstring result := "";
  var integer len := lengthof(hex_str);

  if (len mod 2 != 0) {
    // Add leading zero if odd number of characters
    hex_str := "0" & hex_str;
    len := len + 1;
  }

  for (var integer i := 0; i < len; i := i + 2) {
    // Swap nibbles: "AB" becomes "BA"
    result := result & substr(hex_str, i + 1, 1) & substr(hex_str, i, 1);
  }

  return result;
}

function f_nibbleswap2hex(charstring swapped_str) return charstring {
  var charstring result := "";
  var integer len := lengthof(swapped_str);

  for (var integer i := 0; i < len; i := i + 2) {
    // Swap nibbles back: "BA" becomes "AB"
    result := result & substr(swapped_str, i + 1, 1) & substr(swapped_str, i, 1);
  }

  return result;
}

