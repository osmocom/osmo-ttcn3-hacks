    // ----- JSON ENCODING/DECODING FUNCTIONS -----

    function char2uchar(in charstring cs) return universal charstring {
        return cs;  // TTCN-3 automatic conversion
    }

    function uchar2char(in universal charstring ucs) return charstring {
        return unichar2char(ucs);
    }

    // Safe JSON decoder function
    function f_safe_dec_JSON(in universal charstring p_str) return JSON_PDU {
        @try {
            return dec_JSON(unichar2oct(p_str));
        }
        @catch(err) {
            log("String cannot be deserialized as JSON: ", p_str);
            // Return empty JSON object on error
            var JSON_PDU emptyJson;
            emptyJson.json_object := {};
            return emptyJson;
        }
    }

    // JSON encoding functions using proper JSON_PDU
    function f_encodeInitiateAuthReq(in InitiateAuthentication_Request req) return charstring {
        var JSON_PDU jsonReq;
        var JSON_Object jsonObj := {};

        // Add mandatory fields - convert charstring to universal charstring
        jsonObj[0] := {
            json_name := "euiccChallenge",
            json_value := { json_string := char2uchar(req.euiccChallenge) }
        };

        jsonObj[1] := {
            json_name := "euiccInfo1",
            json_value := { json_string := char2uchar(req.euiccInfo1) }
        };

        var integer idx := 2;

        // Add optional fields if present
        if (ispresent(req.smdpAddress)) {
            jsonObj[idx] := {
                json_name := "smdpAddress",
                json_value := { json_string := char2uchar(req.smdpAddress) }
            };
            idx := idx + 1;
        }

        if (ispresent(req.transactionId)) {
            jsonObj[idx] := {
                json_name := "transactionId",
                json_value := { json_string := char2uchar(req.transactionId) }
            };
        }

        jsonReq.json_object := jsonObj;

        // Encode JSON_PDU to octetstring and then to charstring
        var octetstring octJson := enc_JSON(jsonReq);
        return oct2char(octJson);
    }

