    // ----- TEST CASES -----

    // Test Case: Successful Profile Download
    testcase TC_ES9Plus_SuccessfulProfileDownload() runs on LPA_Simulator {
        var InitiateAuthentication_Response initiateAuthResp;
        var AuthenticateClient_Response authClientResp;
        var GetBoundProfilePackage_Response getBPPResp;

        // Setup test configuration
        f_setupTestConfiguration();

        // Generate test data
        var charstring euiccInfo1 := "SAMPLE_EUICC_INFO1";
        var charstring authenticateServerResponse := "SAMPLE_AUTH_SERVER_RESPONSE";
        var charstring prepareDownloadResponse := "SAMPLE_PREPARE_DOWNLOAD_RESPONSE";

        // Step 1: Initiate Authentication
        initiateAuthResp := f_initiateAuthentication(euiccInfo1, c_SMDP_HOST);
        if (lengthof(initiateAuthResp.transactionId) <= 0) {
            setverdict(fail, "InitiateAuthentication failed");
            // return;
        }

        // Step 2: Authenticate Client
        authClientResp := f_authenticateClient(initiateAuthResp.transactionId, authenticateServerResponse);
        if (lengthof(authClientResp.transactionId) <= 0) {
            setverdict(fail, "AuthenticateClient failed");
            // return;
        }

        // Step 3: Get Bound Profile Package
        getBPPResp := f_getBoundProfilePackage(initiateAuthResp.transactionId, prepareDownloadResponse);
        if (lengthof(getBPPResp.boundProfilePackage) <= 0) {
            setverdict(fail, "GetBoundProfilePackage failed");
            // return;
        }

        // Verify profile package was retrieved successfully
        if (lengthof(v_boundProfilePackage) > 0) {
            setverdict(pass, "Profile downloaded successfully");
        } else {
            setverdict(fail, "Profile download validation failed");
        }

        // Teardown test configuration
        f_teardownTestConfiguration();
    }

    // Test Case: Authentication Failure
    testcase TC_ES9Plus_AuthenticationFailure() runs on LPA_Simulator {
        var InitiateAuthentication_Response initiateAuthResp;
        var AuthenticateClient_Response authClientResp;

        // Setup test configuration
        f_setupTestConfiguration();

        // Generate test data
        var charstring euiccInfo1 := "SAMPLE_EUICC_INFO1";
        var charstring invalidAuthServerResponse := "INVALID_AUTH_SERVER_RESPONSE";

        // Step 1: Initiate Authentication
        initiateAuthResp := f_initiateAuthentication(euiccInfo1, c_SMDP_HOST);
        if (lengthof(initiateAuthResp.transactionId) <= 0) {
            setverdict(fail, "InitiateAuthentication failed");
            // return;
        }

        // Step 2: Authenticate Client with invalid response
        authClientResp := f_authenticateClient(initiateAuthResp.transactionId, invalidAuthServerResponse);

        // Expect authentication to fail
        if (ispresent(authClientResp.errorResult)) {
            setverdict(pass, "Authentication correctly failed with invalid input");
        } else {
            setverdict(fail, "Authentication should have failed but succeeded");
        }

        // Teardown test configuration
        f_teardownTestConfiguration();
    }

    // Test Case: Session Cancellation
    testcase TC_ES9Plus_SessionCancellation() runs on LPA_Simulator {
        var InitiateAuthentication_Response initiateAuthResp;
        var CancelSession_Response cancelSessionResp;

        // Setup test configuration
        f_setupTestConfiguration();

        // Generate test data
        var charstring euiccInfo1 := "SAMPLE_EUICC_INFO1";
        var charstring cancelReason := "USER_CANCELLED";

        // Step 1: Initiate Authentication
        initiateAuthResp := f_initiateAuthentication(euiccInfo1, c_SMDP_HOST);
        if (lengthof(initiateAuthResp.transactionId) <= 0) {
            setverdict(fail, "InitiateAuthentication failed");
            // return;
        }

        // Step 2: Cancel Session
        cancelSessionResp := f_cancelSession(initiateAuthResp.transactionId, cancelReason);

        // Verify cancellation was successful
        if (cancelSessionResp.functionExecutionStatus == "Executed-Success") {
            setverdict(pass, "Session cancelled successfully");
        } else {
            setverdict(fail, "Session cancellation failed");
        }

        // Teardown test configuration
        f_teardownTestConfiguration();
    }

    // Test Case: Handle Notification
    testcase TC_ES9Plus_HandleNotification() runs on LPA_Simulator {
        var HandleNotification_Response handleNotificationResp;

        // Setup test configuration
        f_setupTestConfiguration();

        // Generate test data
        var charstring pendingNotification := "SAMPLE_PENDING_NOTIFICATION";
        var charstring euiccSignPNtoken := "SAMPLE_SIGNED_TOKEN";

        // Step 1: Handle Notification
        handleNotificationResp := f_handleNotification(pendingNotification, euiccSignPNtoken);

        // Verify notification handling was successful
        if (handleNotificationResp.notificationSentResult == "Executed-Success") {
            setverdict(pass, "Notification handled successfully");
        } else {
            setverdict(fail, "Notification handling failed");
        }

        // Teardown test configuration
        f_teardownTestConfiguration();
    }

    // ----- TEST EXECUTION CONTROL -----
    control {
        execute(TC_ES9Plus_SuccessfulProfileDownload());
        execute(TC_ES9Plus_AuthenticationFailure());
        execute(TC_ES9Plus_SessionCancellation());
        execute(TC_ES9Plus_HandleNotification());
    }
}