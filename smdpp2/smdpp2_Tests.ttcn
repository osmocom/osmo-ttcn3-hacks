function f_pmo_to_bitstring(charstring operation) return bitstring {
  select (operation) {
    case ("download") { return '000001'B; }
    case ("install") { return '000010'B; }
    case ("enable") { return '000100'B; }
    case ("disable") { return '001000'B; }
    case ("delete") { return '010000'B; }
    case else { return '000000'B; }
  }
}

// Main component type
type component ES9P_Client_CT {
  var integer v_curl_handle := 0;
  var octetstring v_euicc_cert_der;
  var octetstring v_euicc_key_der;
  var octetstring v_eum_cert_der;
  var octetstring v_ci_cert_der;
  var octetstring v_ci_pkid;
  var charstring v_eid;
  var charstring v_current_transaction_id;
}

// Initialize client
function f_init_client() runs on ES9P_Client_CT {
  log("Initializing ES9+ Client...");

  v_curl_handle := f_curl_init();
  if (v_curl_handle == 0) {
    setverdict(fail, "Failed to initialize cURL");
    return;
  }

  // Set up SSL options
  if (tsp_server_ca_cert != "") {
    f_curl_set_ca_cert(v_curl_handle, tsp_server_ca_cert);
  }

  // Load certificates and keys
  var charstring cert_file := f_file_path_join(tsp_certificate_path, tsp_euicc_certificate);
  var charstring key_file := f_file_path_join(tsp_certificate_path, tsp_euicc_private_key);
  var charstring eum_file := f_file_path_join(tsp_certificate_path, tsp_eum_certificate);
  var charstring ci_file := f_file_path_join(tsp_certificate_path, tsp_ci_certificate);

  v_euicc_cert_der := f_ssl_load_certificate_from_file(cert_file);
  v_euicc_key_der := f_ssl_load_private_key_from_file(key_file);
  v_eum_cert_der := f_ssl_load_certificate_from_file(eum_file);
  v_ci_cert_der := f_ssl_load_certificate_from_file(ci_file);

  if (lengthof(v_euicc_cert_der) == 0 or lengthof(v_euicc_key_der) == 0) {
    setverdict(fail, "Failed to load eUICC certificate or key");
    return;
  }

  // Set client certificate for mutual TLS
  f_curl_set_client_cert(v_curl_handle, cert_file, key_file);

  // Extract EID and CI PKID
  v_eid := f_ssl_extract_subject_serial(v_euicc_cert_der);
  v_ci_pkid := f_ssl_extract_subject_pkid(v_ci_cert_der);

  // Debug output
  var CertificateInfo cert_info := f_ssl_decode_asn1_certificate(v_euicc_cert_der);
  log("EUICC: ", cert_info.subject);

  cert_info := f_ssl_decode_asn1_certificate(v_eum_cert_der);
  log("EUM: ", cert_info.subject);

  cert_info := f_ssl_decode_asn1_certificate(v_ci_cert_der);
  log("CI: ", cert_info.subject);

  log("EID: ", v_eid);
  log("CI PKID: ", oct2hex(v_ci_pkid));
  log("");
}

function f_cleanup_client() runs on ES9P_Client_CT {
  if (v_curl_handle != 0) {
    f_curl_cleanup(v_curl_handle);
  }
}

// HTTP helper function
function f_post_json(charstring endpoint, charstring json_data) runs on ES9P_Client_CT return charstring {
  var charstring url := tsp_es9p_base_url & "/gsma/rsp/es9plus/" & endpoint;

  f_curl_set_url(v_curl_handle, url);
  f_curl_set_post_data(v_curl_handle, json_data);
  f_curl_set_headers(v_curl_handle, {"Content-Type: application/json", "Accept: application/json"});

  var charstring response := f_curl_perform(v_curl_handle);
  var integer response_code := f_curl_get_response_code(v_curl_handle);

  if (response_code != 200) {
    log("HTTP Error: ", response_code);
    setverdict(fail, "HTTP request failed with code: " & int2str(response_code));
  }

  return response;
}

// Download implementation
function f_do_download() runs on ES9P_Client_CT {
  log("Starting ES9+ Download Process...");

  // Step 1: InitiateAuthentication
  log("Step 1: InitiateAuthentication...");

  var ASN1_EuiccInfo1 euicc_info1 := {
    svn := '020400'O,
    euiccCiPKIdListForVerification := { v_ci_pkid },
    euiccCiPKIdListForSigning := { v_ci_pkid }
  };

  var InitiateAuthenticationRequest init_req := {
    euiccChallenge := f_ssl_random(16),
    euiccInfo1 := euicc_info1,
    smdpAddress := tsp_es9p_base_url
  };

  var charstring init_req_json := f_json_encode_initiate_auth_request(init_req);
  var charstring init_resp_json := f_post_json("initiateAuthentication", init_req_json);
  var InitiateAuthenticationResponse init_resp := f_json_decode_initiate_auth_response(init_resp_json);

  log("InitiateAuthentication completed, transactionId: ", init_resp.transactionId);
  v_current_transaction_id := init_resp.transactionId;

  // Step 2: AuthenticateClient
  log("Step 2: AuthenticateClient...");

  var ASN1_EuiccInfo2 euicc_info2 := {
    profileVersion := '020301'O,
    svn := '020400'O,
    euiccFirmwareVer := '23420000'O,
    extCardResource := '8101008204009c6883022223'O,
    uiccCapability := { uiccCapability := '6b36d3c3'O, bitStringLength := 32 },
    javacardVersion := '110200'O,
    globalplatformVersion := '020300'O,
    rspCapability := { rspCapability := '9c'O, bitStringLength := 6 },
    euiccCiPKIdListForVerification := { v_ci_pkid },
    euiccCiPKIdListForSigning := { v_ci_pkid },
    ppVersion := '010000'O,
    sasAcreditationNumber := "OSMOCOM-TEST-1"
  };

  var ASN1_EuiccSigned1 euicc_signed1 := {
    transactionId := str2oct(init_resp.transactionId),
    serverAddress := init_resp.serverSigned1.serverAddress,
    serverChallenge := init_resp.serverSigned1.serverChallenge,
    euiccInfo2 := euicc_info2,
    ctxParams1 := { ctxParamsForCommonAuthentication := {
      matchingId := tsp_matching_id,
      deviceInfo := {
        tac := '35230145'O,
        deviceCapabilities := {}
      }
    }}
  };

  var octetstring euicc_signed1_der := f_asn1_encode_euicc_signed1(euicc_signed1);
  var octetstring euicc_signature1 := f_ssl_ecdsa_sign(euicc_signed1_der, v_euicc_key_der);

  var AuthenticateClientRequest auth_req := {
    transactionId := init_resp.transactionId,
    authenticateServerResponse := { authenticateResponseOk := {
      euiccSigned1 := euicc_signed1,
      euiccSignature1 := euicc_signature1,
      euiccCertificate := v_euicc_cert_der,
      eumCertificate := v_eum_cert_der
    }}
  };

  var charstring auth_req_json := f_json_encode_auth_client_request(auth_req);
  var charstring auth_resp_json := f_post_json("authenticateClient", auth_req_json);
  var AuthenticateClientResponse auth_resp := f_json_decode_auth_client_response(auth_resp_json);

  log("AuthenticateClient completed, transactionId: ", auth_resp.transactionId);

  // Step 3: GetBoundProfilePackage
  log("Step 3: GetBoundProfilePackage...");

  // Generate ECDH keypair
  var ECKeypairResult keypair := f_ssl_generate_ec_keypair("prime256v1");
  var octetstring euicc_otsk := keypair.private_key;
  var octetstring euicc_otpk := keypair.public_key_raw;

  var ASN1_EuiccSigned2 euicc_signed2 := {
    transactionId := str2oct(auth_resp.transactionId),
    euiccOtpk := euicc_otpk
  };

  // Handle confirmation code if required
  if (auth_resp.smdpSigned2.ccRequiredFlag) {
    if (tsp_confirmation_code == "") {
      setverdict(fail, "Confirmation Code required but not provided");
      return;
    }
    var octetstring cc_hash := f_ssl_sha256(str2oct(tsp_confirmation_code));
    euicc_signed2.hashCc := f_ssl_sha256(cc_hash & euicc_signed2.transactionId);
  }

  var octetstring euicc_signed2_der := f_asn1_encode_euicc_signed2(euicc_signed2);
  var octetstring euicc_signature2 := f_ssl_ecdsa_sign(euicc_signed2_der & auth_resp.smdpSignature2, v_euicc_key_der);

  var GetBoundProfilePackageRequest gbp_req := {
    transactionId := auth_resp.transactionId,
    prepareDownloadResponse := { downloadResponseOk := {
      euiccSigned2 := euicc_signed2,
      euiccSignature2 := euicc_signature2
    }}
  };

  var charstring gbp_req_json := f_json_encode_get_bpp_request(gbp_req);
  var charstring gbp_resp_json := f_post_json("getBoundProfilePackage", gbp_req_json);
  var GetBoundProfilePackageResponse gbp_resp := f_json_decode_get_bpp_response(gbp_resp_json);

  log("GetBoundProfilePackage completed, transactionId: ", gbp_resp.transactionId);

  // Decode BPP
  var BPPDecodeResult bpp_result := f_bpp_decode(gbp_resp.boundProfilePackage, euicc_otsk, v_eid);
  if (bpp_result.success != 1) {
    setverdict(fail, "Failed to decode BoundProfilePackage");
    return;
  }

  // Extract ICCID and create filenames
  var charstring iccid_hex := oct2char(bpp_result.iccid);
  var charstring iccid_nibbleswapped := f_nibbleswap2hex(iccid_hex);
  var charstring base_filename := f_file_path_join(tsp_output_path, iccid_nibbleswapped);

  log("SUCCESS: Storing files as ", base_filename, ".*.der");

  // Write output files
  f_file_write_binary(base_filename & ".upp.der", bpp_result.upp);
  f_file_write_binary(base_filename & ".isdp.der", bpp_result.configureISDPRequest);
  f_file_write_binary(base_filename & ".smr.der", bpp_result.storeMetadataRequest);

  setverdict(pass);
}

// Notification implementation
function f_do_notification() runs on ES9P_Client_CT {
  log("Sending ES9+ Notification...");

var charstring nfa := tsp_notification_address;
if (tsp_notification_address == "") {
  nfa := tsp_es9p_base_url;
}


  var ASN1_NotificationMetadata ntf_metadata := {
    seqNumber := tsp_sequence_nr,
    profileManagementOperation := f_pmo_to_bitstring(tsp_operation),
    notificationAddress := nfa
  };

  if (tsp_iccid != "") {
    ntf_metadata.iccid := str2oct(f_hex2nibbleswap(tsp_iccid));
  }

  var PendingNotification pn;

  if (tsp_operation == "notification-install") {
    // Installation notification
    var ASN1_ProfileInstallationResultData pird := {
      transactionId := tsp_transaction_id,
      notificationMetadata := ntf_metadata,
      smdpOid := tsp_smdpp_oid,
      finalResult := { successResult := {
        aid := str2oct(tsp_isdp_aid),
        simaResponse := str2oct(tsp_sima_response)
      }}
    };

    var octetstring pird_der := f_asn1_encode_profile_installation_result_data(pird);
    var octetstring csignature := f_ssl_ecdsa_sign(pird_der, v_euicc_key_der);

    pn := { profileInstallationResult := {
      profileInstallationResultData := pird,
      euiccSignPIR := csignature
    }};
  } else {
    // Other notification
    var octetstring ntf_der := f_asn1_encode_notification_metadata(ntf_metadata);
    var octetstring csignature := f_ssl_ecdsa_sign(ntf_der, v_euicc_key_der);

    pn := { otherSignedNotification := {
      tbsOtherNotification := ntf_metadata,
      euiccNotificationSignature := csignature,
      euiccCertificate := v_euicc_cert_der,
      eumCertificate := v_eum_cert_der
    }};
  }

  var HandleNotificationRequest req := {
    pendingNotification := pn
  };

  var charstring req_json := f_json_encode_handle_notification_request(req);
  var charstring resp_json := f_post_json("handleNotification", req_json);

  log("Notification sent successfully");
  setverdict(pass);
}

// Main execution logic
function f_main() runs on ES9P_Client_CT {
  f_init_client();

  select (tsp_command) {
    case ("download") {
      f_do_download();
    }
    case ("notification") {
      if (tsp_operation == "") {
        setverdict(fail, "Operation not specified for notification");
        return;
      }
      f_do_notification();
    }
    case ("notification-install") {
      // tsp_operation := "install";
      f_do_notification();
    }
    case else {
      setverdict(fail, "Unknown command: " & tsp_command);
    }
  }

  f_cleanup_client();
}

// Test case
testcase TC_ES9P_Client() runs on ES9P_Client_CT {
  f_main();
}

// Control part
control {
  execute(TC_ES9P_Client());
}

}