    // ----- TEST CONFIGURATION -----
    function f_setupTestConfiguration() runs on LPA_Simulator {
        var HTTP_Adapter_Params http_params := {
            http_host := c_SMDP_HOST,
            http_port := c_SMDP_PORT,
            use_ssl := c_USE_SSL
        };
        f_http_init(http_params);
    }

    function f_teardownTestConfiguration() runs on LPA_Simulator {
        // Nothing special needed for teardown with adapter
    }

    // ----- JSON ENCODING/DECODING FUNCTIONS -----

    import from smdpp2_json all;

    // ----- UTILITY FUNCTIONS -----

    // Simple JSON string value extractor (simplified implementation)
    function f_extractJsonStringValue(in charstring json, in charstring key) return charstring {
        var charstring pattern_str := "*\"" & key & "\"*:*\"";
        var integer start_idx := lengthof("\"" & key & "\":");
        var integer pos := 0;
        var integer end_pos := 0;
        var charstring result := "";

        // Find the key
        if (match(json, pattern pattern_str & "*")) {
            // Find start of value
            for (var integer i := 0; i < lengthof(json); i := i + 1) {
                if (substr(json, i, lengthof(key) + 3) == "\"" & key & "\":") {
                    pos := i + lengthof(key) + 3;
                    break;
                }
            }

            // Skip whitespace
            while (pos < lengthof(json) and (substr(json, pos, 1) == " " or substr(json, pos, 1) == "\t")) {
                pos := pos + 1;
            }

            // Find value between quotes
            if (pos < lengthof(json) and substr(json, pos, 1) == "\"") {
                pos := pos + 1; // Skip opening quote
                end_pos := pos;

                // Find closing quote
                while (end_pos < lengthof(json) and substr(json, end_pos, 1) != "\"") {
                    end_pos := end_pos + 1;
                }

                if (end_pos > pos) {
                    result := substr(json, pos, end_pos - pos);
                }
            }
        }

        return result;
    }

    // Generate random EuiccChallenge
    function f_generateEuiccChallenge() return octetstring {
        var octetstring randomBytes := f_rnd_octstring(16); // 16 byte random value
        return randomBytes;
    }

    function f_rnd_octstring(in integer len) return octetstring {
        var octetstring result := ''O;
        for (var integer i := 0; i < len; i := i + 1) {
            result := result & int2oct(float2int(rnd() * 255.0), 1);
        }
        return result;
    }

    // Load certificate from file (external function)
    function f_loadCertificate(in charstring path) return Certificate {
        // This would be implemented as external function
        var Certificate cert := {
            serialNumber := "",
            issuerName := "",
            subjectName := "",
            validFrom := "",
            validTo := "",
            publicKey := "",
            signatureAlgorithm := "",
            signaturex := "",
            extensions := omit
        };
        return cert;
    }

    // Verify certificate chain (external function)
    function f_verifyCertificateChain(
        in Certificate targetCert,
        in Certificate intermediateCert,
        in Certificate rootCert
    ) return boolean {
        // This would be implemented as external function
        return true;
    }

    // Verify signature (external function)
    function f_verifySignature(
        in Certificate signerCert,
        in octetstring signedData,
        in octetstring xsignature,
        in octetstring signatureAlgorithmOID
    ) return boolean {
        // This would be implemented as external function
        return true;
    }

    // Decode certificate from string
    function f_decodeCertificate(in charstring certStr) return Certificate {
        // This would be implemented properly
        var Certificate cert := {
            serialNumber := "",
            issuerName := "",
            subjectName := "",
            validFrom := "",
            validTo := "",
            publicKey := "",
            signatureAlgorithm := "",
            signaturex := "",
            extensions := omit
        };
        return cert;
    }

    // Verify server signature
    function f_verifyServerSignature(
        in charstring serverCertificate,
        in charstring serverSigned,
        in charstring serverSignature
    ) return boolean {
        var Certificate smdpCert := f_decodeCertificate(serverCertificate);
        var octetstring signedData := str2oct(serverSigned);
        var octetstring xsignature := str2oct(serverSignature);

        // Load CI certificate (intermediate cert in the chain)
        var Certificate ciCert := f_loadCertificate(c_CI_CERT_PATH);
        // Load root CA certificate
        var Certificate rootCACert := f_loadCertificate(c_ROOT_CA_PATH);

        // First verify certificate chain
        var boolean certChainValid := f_verifyCertificateChain(smdpCert, ciCert, rootCACert);
        if (not certChainValid) {
            log("Certificate chain validation failed for SM-DP+ certificate");
            return false;
        }

        // Then verify the signature
        return f_verifySignature(smdpCert, signedData, xsignature, c_OID_SHA256_WITH_RSA);
    }


    // Log certificate details
    function f_logCertificateDetails(in Certificate cert) {
        log("Certificate Details:");
        log("  Serial Number: ", cert.serialNumber);
        log("  Issuer: ", cert.issuerName);
        log("  Subject: ", cert.subjectName);
        log("  Valid From: ", cert.validFrom);
        log("  Valid To: ", cert.validTo);
        log("  Signature Algorithm: ", cert.signatureAlgorithm);
    }

    // ----- MAIN PROCEDURES USING HTTP ADAPTER -----

    template (value) HeaderLines ts_rsp_HTTP_Header := {
        { header_name := "User-Agent", header_value := "TTCN3 smdpp testsuite" },
        { header_name := "X-Admin-Protocol", header_value := "gsma/rsp/v2.5.0" },
        { header_name := "Content-Type", header_value := "application/json;charset=UTF-8" }
    };

    // Initiate Authentication procedure
    function f_initiateAuthentication(
        in charstring euiccInfo1,
        in charstring smdpAddress
    ) runs on LPA_Simulator return InitiateAuthentication_Response {
        var HTTPMessage response;
        var InitiateAuthentication_Request req;
        var InitiateAuthentication_Response resp := {};
        var charstring jsonBody;
        var HeaderLines customHeaders := valueof(ts_rsp_HTTP_Header);

        // Generate eUICC challenge
        v_euiccChallenge := f_generateEuiccChallenge();

        // Load eUICC certificate
        v_euiccCert := f_loadCertificate(c_EUICC_CERT_PATH);
        f_logCertificateDetails(v_euiccCert);

        // Create request body
        req := {
            euiccChallenge := encode_base64(v_euiccChallenge),
            euiccInfo1 := encode_base64(str2oct(euiccInfo1)),
            smdpAddress := c_server_name,
            transactionId := omit
        }

        // Convert to JSON
        jsonBody := f_encodeInitiateAuthReq(req);

        log("Sending InitiateAuthentication request");

        // Use HTTP adapter to send request
        response := f_http_transact(
            url := "/gsma/rsp2/es9plus/initiateAuthentication",
            method := "POST",
            body := jsonBody,
            exp := tr_HTTP_Resp(c_HTTP_OK),
            tout := 30.0,
            custom_hdr := customHeaders
        );

        log("Received InitiateAuthentication response, status: ", response.response.statuscode);

        // Extract and parse response
        var charstring responseBody := response.response.body;
        resp := f_decodeInitiateAuthResp(responseBody);

        // Store transaction ID for future requests
        v_currentTransactionId := resp.transactionId;

        // Validate server certificate
        if (lengthof(resp.serverCertificate) > 0) {
            v_smdpCert := f_decodeCertificate(resp.serverCertificate);
            f_logCertificateDetails(v_smdpCert);

            // Load CI certificate
            v_ciCert := f_loadCertificate(c_CI_CERT_PATH);

            // Load root CA certificate
            var Certificate rootCACert := f_loadCertificate(c_ROOT_CA_PATH);

            // Verify certificate chain
            v_certChainValid := f_verifyCertificateChain(v_smdpCert, v_ciCert, rootCACert);

            if (not v_certChainValid) {
                log("Warning: SM-DP+ certificate chain validation failed");
            } else {
                log("SM-DP+ certificate chain validation successful");

                // Verify serverSignature1
                var boolean signatureValid := f_verifyServerSignature(
                    resp.serverCertificate,
                    resp.serverSigned1,
                    resp.serverSignature1
                );

                if (not signatureValid) {
                    log("Warning: Server signature validation failed");
                } else {
                    log("Server signature validation successful");
                }
            }
        }

        return resp;
    }

    // Authenticate Client procedure
    function f_authenticateClient(
        in charstring transactionId,
        in charstring authenticateServerResponse
    ) runs on LPA_Simulator return AuthenticateClient_Response {
        var HTTPMessage response;
        var AuthenticateClient_Request req;
        var AuthenticateClient_Response resp := {};
        var charstring jsonBody;
        var HeaderLines customHeaders := valueof(ts_rsp_HTTP_Header);

        // Create request body
        req := {
            transactionId := transactionId,
            authenticateServerResponse := authenticateServerResponse
        }

        // Convert to JSON
        jsonBody := f_encodeAuthClientReq(req);

        log("Sending AuthenticateClient request");

        // Use HTTP adapter to send request
        response := f_http_transact(
            url := "/gsma/rsp2/es9plus/authenticateClient",
            method := "POST",
            body := jsonBody,
            exp := tr_HTTP_Resp2xx,
            tout := 30.0,
            custom_hdr := customHeaders
        );

        log("Received AuthenticateClient response, status: ", response.response.statuscode);

        // Extract and parse response
        var charstring responseBody := response.response.body;

        // Check for error response first
        if (response.response.statuscode != c_HTTP_OK) {
            resp.errorResult := responseBody;
            return resp;
        }

        resp := f_decodeAuthClientResp(responseBody);

        // Verify smdpSignature2
        if (v_certChainValid and lengthof(resp.smdpSignature2) > 0) {
            var boolean signatureValid := f_verifyServerSignature(
                resp.smdpCertificate,
                resp.smdpSigned2,
                resp.smdpSignature2
            );

            if (not signatureValid) {
                log("Warning: SM-DP+ signature validation failed in AuthenticateClient");
            } else {
                log("SM-DP+ signature validation successful in AuthenticateClient");
            }
        }

        // Parse profile metadata
        if (lengthof(resp.profileMetadata) > 0) {
            v_profileMetadata := f_parseProfileMetadata(resp.profileMetadata);
            log("Profile ICCID: ", v_profileMetadata.iccid);
            log("Profile Name: ", v_profileMetadata.profileName);
            log("Service Provider: ", v_profileMetadata.serviceProviderName);
        }

        return resp;
    }

    // Get Bound Profile Package procedure
    function f_getBoundProfilePackage(
        in charstring transactionId,
        in charstring prepareDownloadResponse
    ) runs on LPA_Simulator return GetBoundProfilePackage_Response {
        var HTTPMessage response;
        var GetBoundProfilePackage_Request req;
        var GetBoundProfilePackage_Response resp := {};
        var charstring jsonBody;
var HeaderLines customHeaders := valueof(ts_rsp_HTTP_Header);

        // Create request body
        req := {
            transactionId := transactionId,
            prepareDownloadResponse := prepareDownloadResponse
        }

        // Convert to JSON
        jsonBody := f_encodeGetBPPReq(req);

        // Use HTTP adapter to send request
        response := f_http_transact(
            url := "/gsma/rsp2/es9plus/getBoundProfilePackage",
            method := "POST",
            body := jsonBody,
            exp := tr_HTTP_Resp(c_HTTP_OK),
            tout := 30.0,
            custom_hdr := customHeaders
        );

        // Extract and parse response
        var charstring responseBody := response.response.body;
        resp := f_decodeGetBPPResp(responseBody);

        // Store bound profile package for later use
        v_boundProfilePackage := resp.boundProfilePackage;

        return resp;
    }

