private function f_TC_testme(charstring id) runs on eIM_ConnHdlr {
	var charstring es9p_req;
	var RemoteProfileProvisioningResponse es9p_res;
	var charstring es9p_res_json;
	var RemoteProfileProvisioningRequest asn1_pdu_dec;

	f_http_register();

	es9p_req := f_es9p_transceive_empty_response();

	log("===============================================");
	dec_RemoteProfileProvisioningRequest_from_JSON(es9p_req, asn1_pdu_dec);
	log(asn1_pdu_dec);
	log("===============================================");


	es9p_res := valueof(ts_getBoundProfilePackageResponse('AAAAAAAA'O, ts_boundProfilePackage));
	enc_RemoteProfileProvisioningResponse_to_JSON(es9p_res, es9p_res_json);

	log("================== ENCODER RESULT ==================");
	log(es9p_res_json);
	log("================== ENCODER RESULT ==================");


	/* Wait some time until the the HTTP response is actually delivered */
	f_sleep(2.0);


	setverdict(pass);
}
testcase TC_testme() runs on MTC_CT {
	var charstring id := testcasename();
	var eIM_ConnHdlrPars pars := f_init_pars();
	var eIM_ConnHdlr vc_conn;
	f_init(id);
	vc_conn := f_start_handler(refers(f_TC_testme), pars);
	vc_conn.done;
	setverdict(pass);
}

template (value) HeaderLines ts_esipa_HTTP_Header := {
	 { header_name := "User-Agent", header_value := "TTCN3 eIM testsuite" },
	 { header_name := "X-Admin-Protocol", header_value := "gsma/rsp/v2.5.0" },
	 { header_name := "Content-Type", header_value := "application/x-gsma-rsp-asn1" }
};

private function f_TC_testme2(charstring id) runs on eIM_ConnHdlr {
	var HTTPMessage http_resp;
	f_http_init(mp_esipa_ip, mp_esipa_port, not mp_esipa_disable_ssl);

	log("======================== HTTP REQUEST ========================");
	http_resp := f_http_transact(url := "/", method := "GET", exp := tr_HTTP_Resp(200), custom_hdr := valueof(ts_esipa_HTTP_Header));
	log("======================== HTTP RESPONSE =======================");
	log(http_resp);
	log("======================== HTTP DONE ========================");

	setverdict(pass);
}
testcase TC_testme2() runs on MTC_CT {
	var charstring id := testcasename();
	var eIM_ConnHdlrPars pars := f_init_pars();
	var eIM_ConnHdlr vc_conn;
	f_init(id);
	vc_conn := f_start_handler(refers(f_TC_testme2), pars);
	vc_conn.done;
	setverdict(pass);
}

control {
//	execute ( TC_testme() );
	execute ( TC_testme2() );
}

}