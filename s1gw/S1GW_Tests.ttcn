	f_ConnHdlr_handover_req_();
	f_ConnHdlr_handover_ack_();
	f_ConnHdlr_erab_release_cmd_();
	f_ConnHdlr_erab_release_rsp_();

	f_ConnHdlr_s1ap_disconnect();
	f_ConnHdlr_s1ap_unregister(g_pars.genb_id);
